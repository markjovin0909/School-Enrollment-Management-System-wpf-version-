<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="DialogWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
        <Setter Property="WindowStartupLocation" Value="CenterOwner"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="MinWidth" Value="520"/>
        <Setter Property="MinHeight" Value="320"/>
    </Style>

    <Style x:Key="DialogRootGrid" TargetType="Grid">
        <Setter Property="Margin" Value="20"/>
    </Style>

    <Style x:Key="DialogShell" TargetType="Border" BasedOn="{StaticResource CardPanel}">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <Style x:Key="DialogSection" TargetType="Border" BasedOn="{StaticResource CardPanel}">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="DialogHeaderTitle" TargetType="TextBlock" BasedOn="{StaticResource Text.SectionTitle}">
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="DialogHeaderSubtitle" TargetType="TextBlock" BasedOn="{StaticResource Text.Subtitle}">
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="DialogActionBar" TargetType="DockPanel">
        <Setter Property="LastChildFill" Value="False"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
    </Style>

    <Style x:Key="DialogDangerActionButton" TargetType="Button" BasedOn="{StaticResource DangerGhostButton}">
        <Setter Property="MinWidth" Value="110"/>
    </Style>

    <Style x:Key="DialogPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource PageActionButton}">
        <Setter Property="MinWidth" Value="110"/>
    </Style>

    <Style x:Key="StatusBadge.Pending" TargetType="Border">
        <Setter Property="Background" Value="#FFF7ED"/>
        <Setter Property="BorderBrush" Value="#FDBA74"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style x:Key="StatusBadge.Enrolled" TargetType="Border">
        <Setter Property="Background" Value="#ECFEFF"/>
        <Setter Property="BorderBrush" Value="#67E8F9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style x:Key="StatusBadge.Danger" TargetType="Border">
        <Setter Property="Background" Value="#FEF2F2"/>
        <Setter Property="BorderBrush" Value="#FCA5A5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,2"/>
    </Style>

    <Style x:Key="InfoBanner" TargetType="Border">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="BorderBrush" Value="#BFDBFE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#EFF6FF"/>
    </Style>

    <Style x:Key="WarningBanner" TargetType="Border" BasedOn="{StaticResource InfoBanner}">
        <Setter Property="BorderBrush" Value="#FCD34D"/>
        <Setter Property="Background" Value="#FFFBEB"/>
    </Style>

    <Style x:Key="ErrorBanner" TargetType="Border" BasedOn="{StaticResource InfoBanner}">
        <Setter Property="BorderBrush" Value="#FCA5A5"/>
        <Setter Property="Background" Value="#FEF2F2"/>
    </Style>

    <Style x:Key="SuccessBanner" TargetType="Border" BasedOn="{StaticResource InfoBanner}">
        <Setter Property="BorderBrush" Value="#86EFAC"/>
        <Setter Property="Background" Value="#ECFDF3"/>
    </Style>

    <Style x:Key="ToastBanner.Info" TargetType="Border" BasedOn="{StaticResource InfoBanner}">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style x:Key="ToastBanner.Success" TargetType="Border" BasedOn="{StaticResource InfoBanner}">
        <Setter Property="Background" Value="#ECFDF3"/>
        <Setter Property="BorderBrush" Value="#86EFAC"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style x:Key="ToastBanner.Error" TargetType="Border" BasedOn="{StaticResource ErrorBanner}">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <!-- Personal information / person profile form patterns -->
    <Style x:Key="PersonProfileHero" TargetType="Border">
        <Setter Property="Background" Value="#E8F2FC"/>
        <Setter Property="BorderBrush" Value="#C5DCF5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="PersonAvatarRing" TargetType="Border">
        <Setter Property="Width" Value="52"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="CornerRadius" Value="26"/>
        <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="BorderBrush" Value="#9BC7EE"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PersonAvatarInitials" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PersonProfileName" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Heading}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="PersonProfileMeta" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="PersonStatusChip" TargetType="Border">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PersonFormSection" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="PersonFormSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Text.CaptionStrong}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="PersonFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style x:Key="PersonFieldGroup" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="PersonActionBar" TargetType="Border">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="PersonDetailSubCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
</ResourceDictionary>
