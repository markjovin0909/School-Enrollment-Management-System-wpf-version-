<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <FontFamily x:Key="FontFamily.Icon">Segoe MDL2 Assets</FontFamily>

    <!-- Common glyph references -->
    <sys:String x:Key="Icon.Search">&#xE721;</sys:String>
    <sys:String x:Key="Icon.Refresh">&#xE72C;</sys:String>
    <sys:String x:Key="Icon.Add">&#xE710;</sys:String>
    <sys:String x:Key="Icon.Edit">&#xE70F;</sys:String>
    <sys:String x:Key="Icon.Delete">&#xE74D;</sys:String>
    <sys:String x:Key="Icon.Export">&#xEDE1;</sys:String>
    <sys:String x:Key="Icon.Warning">&#xE7BA;</sys:String>
    <sys:String x:Key="Icon.Info">&#xE946;</sys:String>
    <sys:String x:Key="Icon.Close">&#xE711;</sys:String>
    <sys:String x:Key="Icon.ChevronRight">&#xE76C;</sys:String>

    <Style x:Key="GlyphIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Icon}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
    </Style>

    <!-- Dialog / modal close control: Path-based so it never falls back to a broken glyph -->
    <Style x:Key="DialogCloseButton" TargetType="Button">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="MinWidth" Value="32"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ToolTip" Value="Close"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Path x:Name="CloseGlyph"
                              Width="11"
                              Height="11"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stroke="#475569"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M0,0 L11,11 M11,0 L0,11"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FEE2E2"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#FCA5A5"/>
                            <Setter TargetName="CloseGlyph" Property="Stroke" Value="#B91C1C"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FECACA"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#F87171"/>
                            <Setter TargetName="CloseGlyph" Property="Stroke" Value="#991B1B"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
