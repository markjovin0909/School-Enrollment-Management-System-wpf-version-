<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <FontFamily x:Key="FontFamily.Icon">Segoe MDL2 Assets</FontFamily>

    <!-- Common glyph references -->
    <sys:String x:Key="Icon.Search">&#xE721;</sys:String>
    <sys:String x:Key="Icon.Refresh">&#xE72C;</sys:String>
    <sys:String x:Key="Icon.Add">&#xE710;</sys:String>
    <sys:String x:Key="Icon.Edit">&#xE70F;</sys:String>
    <sys:String x:Key="Icon.Delete">&#xE74D;</sys:String>
    <sys:String x:Key="Icon.Export">&#xEDE1;</sys:String>
    <sys:String x:Key="Icon.Warning">&#xE7BA;</sys:String>
    <sys:String x:Key="Icon.Info">&#xE946;</sys:String>

    <Style x:Key="GlyphIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Icon}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
    </Style>
</ResourceDictionary>
