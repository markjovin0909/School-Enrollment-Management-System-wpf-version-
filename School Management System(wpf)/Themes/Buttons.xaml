<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.PrimaryHover}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.PrimaryPressed}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Brush.PrimaryPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#EEF3FA"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="#F5F8FC"/>
        <Setter Property="BorderBrush" Value="#C7D5E7"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#ECF2FA"/>
                <Setter Property="BorderBrush" Value="#AFC4DE"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#E2ECF9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PageActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="#EAF2FC"/>
        <Setter Property="BorderBrush" Value="#B8CCE4"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinWidth" Value="122"/>
        <Setter Property="MinHeight" Value="36"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#DFECFC"/>
                <Setter Property="BorderBrush" Value="#9BB9DB"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#D3E4FA"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerGhostButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
        <Setter Property="BorderBrush" Value="#F3C8C8"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FEF2F2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SideNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="14,11"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Background" Value="{StaticResource Brush.NavButton}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.NavButtonBorder}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.NavButtonText}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.NavButtonHover}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.NavButtonActiveBorder}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#163958"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SideNavMajorButton" TargetType="Button" BasedOn="{StaticResource SideNavButton}">
        <Setter Property="Background" Value="#142F4B"/>
        <Setter Property="BorderBrush" Value="#2C4F74"/>
        <Setter Property="Foreground" Value="#D2E5FA"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1D3E61"/>
                <Setter Property="BorderBrush" Value="#3B6794"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#17344F"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SideNavSubButton" TargetType="Button" BasedOn="{StaticResource SideNavButton}">
        <Setter Property="Background" Value="#12283F"/>
        <Setter Property="BorderBrush" Value="#224668"/>
        <Setter Property="Foreground" Value="#C8DCF4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Margin" Value="10,0,0,6"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1A3858"/>
                <Setter Property="BorderBrush" Value="#3A678F"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#152F4A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#ECF2FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OpsModuleButton" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="WorkbenchPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="WorkbenchSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="WorkbenchDangerActionButton" TargetType="Button" BasedOn="{StaticResource DangerGhostButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>
</ResourceDictionary>
