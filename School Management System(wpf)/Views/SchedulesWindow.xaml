<Window x:Class="School_Management_System.Views.SchedulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Schedules"
        Width="1320" Height="780"
        MinWidth="1120" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.65*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Schedules"
                                Subtitle="Class schedules"
                                Margin="0,0,0,10"/>

        <Border x:Name="searchPanel" Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnNew" Content="New Schedule" Width="114" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="btnListEdit" Content="Edit" Width="80" Margin="0,0,8,0" Style="{StaticResource EditActionButton}"/>
                <Button Grid.Column="2" x:Name="btnListDelete" Content="Delete" Width="80" Margin="0,0,8,0" Style="{StaticResource DeleteActionButton}"/>
                <ComboBox Grid.Column="3" x:Name="cboFilterSchoolYear" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="4" x:Name="cboFilterTeacher" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="5" x:Name="cboFilterSection" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                <TextBox Grid.Column="6" x:Name="txtSearch" Margin="0,0,8,0"/>
                <Button Grid.Column="7" x:Name="btnRefresh" Content="Refresh" Width="80" Style="{StaticResource RefreshActionButton}"/>
            </Grid>
        </Border>

        <Border x:Name="listPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Schedule Registry"
                           Style="{StaticResource Text.SectionTitle}"
                           Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1"
                          x:Name="gridSchedules"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="editorPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <controls:SectionHeader Title="Schedule Details" Subtitle="" Margin="0,0,0,8"/>
                    <Border x:Name="scheduleWarningPanel" Style="{StaticResource WarningBanner}" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock x:Name="txtScheduleWarnings" TextWrapping="Wrap"/>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Class Offering"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Room"/>
                        <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboOffering" DisplayMemberPath="Label" SelectedValuePath="Id" Style="{StaticResource MediumField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboRoom" DisplayMemberPath="Label" SelectedValuePath="Id" Style="{StaticResource CompactField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Time Slot" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="Day" Margin="0,12,0,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="0" x:Name="cboTimeSlot" DisplayMemberPath="Label" SelectedValuePath="Id" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" x:Name="cboDay" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Start (HH:mm)" Margin="0,12,0,0"/>
                        <Label Grid.Row="4" Grid.Column="2" Content="End (HH:mm)" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="5" Grid.Column="0" x:Name="txtStart" Style="{StaticResource NarrowField}"/>
                        <TextBox Grid.Row="5" Grid.Column="2" x:Name="txtEnd" Style="{StaticResource NarrowField}"/>
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="btnAdd" Content="Create" Width="90"/>
                        <Button x:Name="btnSave" Content="Save" Width="90"/>
                        <Button x:Name="btnDelete" Content="Delete" Width="80" Style="{StaticResource DeleteActionButton}"/>
                        <Button x:Name="btnClear" Content="Clear" Width="80" Style="{StaticResource CancelActionButton}"/>
                        <Button x:Name="btnExport" Content="Export" Width="90" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
