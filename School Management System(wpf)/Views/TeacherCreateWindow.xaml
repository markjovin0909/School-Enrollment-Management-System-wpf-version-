<Window x:Class="School_Management_System.Views.TeacherCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Teacher"
        Width="840"
        Height="720"
        MinWidth="720"
        MinHeight="620"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="CompactField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="NarrowField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="280"/>
            </Style>
            <Style x:Key="WideField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="360"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource DialogRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource DialogShell}">
                <StackPanel>
                    <TextBlock x:Name="txtDialogTitle" Text="Create Teacher" Style="{StaticResource DialogHeaderTitle}"/>
                    <TextBlock x:Name="txtDialogSubtitle" Text="Create a teacher profile and linked managed account in a dedicated form, keeping creation separate from later editing."
                               Style="{StaticResource DialogHeaderSubtitle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="validationSummaryHost"
                    Grid.Row="1"
                    Style="{StaticResource ErrorBanner}"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
                <TextBlock x:Name="txtValidationSummary"
                           Foreground="{StaticResource Brush.Danger}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Account" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Employee Number"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Account ID"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtTeacherEmployeeNo" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtTeacherUsername" Style="{StaticResource CompactField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Profile Image Path" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="Initial Password" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtTeacherProfileImage" Style="{StaticResource WideField}"/>
                        <PasswordBox Grid.Row="3" Grid.Column="2" x:Name="txtTeacherInitialPassword" Style="{StaticResource CompactField}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Identity" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="First Name"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Middle Name"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Last Name"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtTeacherFirst" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtTeacherMiddle" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtTeacherLast" Style="{StaticResource CompactField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Email" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="4" Content="Contact Number" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" x:Name="txtTeacherEmail" Style="{StaticResource WideField}"/>
                        <TextBox Grid.Row="3" Grid.Column="4" x:Name="txtTeacherContact" Style="{StaticResource NarrowField}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Employment and Assignment" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Specialization"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Advisory Status"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Employment Status"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtTeacherSpecialization" Style="{StaticResource MediumField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboTeacherAdvisoryStatus" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="4" x:Name="cboTeacherEmploymentStatus" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Hire Date" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="Status" Margin="0,12,0,0"/>
                        <DatePicker Grid.Row="3" Grid.Column="0" x:Name="dpTeacherHireDate" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" x:Name="cboTeacherStatus" Style="{StaticResource CompactField}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="5" Style="{StaticResource DialogActionBar}" LastChildFill="False">
                <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnCreate" Content="Create Teacher" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnClear" Content="Clear" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
