<Window x:Class="School_Management_System.Views.TeacherCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Teacher"
        Width="900"
        Height="760"
        MinWidth="760"
        MinHeight="660"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource DialogRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource DialogShell}">
                <StackPanel>
                    <TextBlock Text="Create Teacher" Style="{StaticResource DialogHeaderTitle}"/>
                    <TextBlock Text="Create a teacher profile and linked managed account in a dedicated form, keeping creation separate from later editing."
                               Style="{StaticResource DialogHeaderSubtitle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="validationSummaryHost"
                    Grid.Row="1"
                    Style="{StaticResource ErrorBanner}"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
                <TextBlock x:Name="txtValidationSummary"
                           Foreground="{StaticResource Brush.Danger}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Account" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Employee Number"/>
                        <Label Grid.Row="0" Grid.Column="1" Content="Account ID"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtTeacherEmployeeNo" Margin="0,0,8,12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtTeacherUsername" Margin="8,0,0,12"/>

                        <Label Grid.Row="2" Grid.ColumnSpan="2" Content="Profile Image Path"/>
                        <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtTeacherProfileImage" Margin="0,0,0,12"/>

                        <Label Grid.Row="4" Grid.ColumnSpan="2" Content="Initial Password"/>
                        <PasswordBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="txtTeacherInitialPassword"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Identity" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="First Name"/>
                        <Label Grid.Row="0" Grid.Column="1" Content="Last Name"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtTeacherFirst" Margin="0,0,8,12"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtTeacherLast" Margin="8,0,0,12"/>

                        <Label Grid.Row="2" Grid.ColumnSpan="2" Content="Middle Name"/>
                        <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtTeacherMiddle" Margin="0,0,0,12"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Email"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Contact Number"/>
                        <TextBox Grid.Row="5" Grid.Column="0" x:Name="txtTeacherEmail" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtTeacherContact" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Employment and Assignment" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Specialization"/>
                        <TextBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="txtTeacherSpecialization" Margin="0,0,0,12"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Advisory Status"/>
                        <Label Grid.Row="2" Grid.Column="1" Content="Employment Status"/>
                        <ComboBox Grid.Row="3" Grid.Column="0" x:Name="cboTeacherAdvisoryStatus" Margin="0,0,8,12"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cboTeacherEmploymentStatus" Margin="8,0,0,12"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Hire Date"/>
                        <Label Grid.Row="4" Grid.Column="1" Content="Status"/>
                        <DatePicker Grid.Row="5" Grid.Column="0" x:Name="dpTeacherHireDate" Margin="0,0,8,0"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cboTeacherStatus" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="5" Style="{StaticResource DialogActionBar}" LastChildFill="False">
                <Button x:Name="btnCancel" Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnCreate" Content="Create Teacher" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnClear" Content="Clear" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
