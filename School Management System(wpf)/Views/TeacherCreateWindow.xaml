<Window x:Class="School_Management_System.Views.TeacherCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Teacher"
        Width="860"
        Height="740"
        MinWidth="740"
        MinHeight="640"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource DialogRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource DialogShell}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource PersonAvatarRing}" Margin="0,0,14,0" Width="56" Height="56" CornerRadius="28">
                        <TextBlock x:Name="txtDialogInitials" Text="TC" Style="{StaticResource PersonAvatarInitials}" FontSize="18"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="txtDialogTitle" Text="Create Teacher" Style="{StaticResource DialogHeaderTitle}"/>
                        <TextBlock x:Name="txtDialogSubtitle"
                                   Text="Enter personal and employment details. A managed account is linked automatically."
                                   Style="{StaticResource DialogHeaderSubtitle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="validationSummaryHost"
                    Grid.Row="1"
                    Style="{StaticResource ErrorBanner}"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
                <TextBlock x:Name="txtValidationSummary"
                           Foreground="{StaticResource Brush.Danger}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Account -->
            <Border Grid.Row="2" Style="{StaticResource PersonFormSection}">
                <StackPanel>
                    <TextBlock Text="Account" Style="{StaticResource PersonFormSectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Employee Number" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherEmployeeNo"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Account ID" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherUsername"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Profile Image Path" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherProfileImage"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Initial Password" Style="{StaticResource PersonFieldLabel}"/>
                            <PasswordBox x:Name="txtTeacherInitialPassword"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Personal Information -->
            <Border Grid.Row="3" Style="{StaticResource PersonFormSection}">
                <StackPanel>
                    <TextBlock Text="Personal Information" Style="{StaticResource PersonFormSectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="First Name" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherFirst"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Middle Name" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherMiddle"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Last Name" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherLast"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Email" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherEmail"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Contact Number" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherContact"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Employment -->
            <Border Grid.Row="4" Style="{StaticResource PersonFormSection}">
                <StackPanel>
                    <TextBlock Text="Employment &amp; Assignment" Style="{StaticResource PersonFormSectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Specialization" Style="{StaticResource PersonFieldLabel}"/>
                            <TextBox x:Name="txtTeacherSpecialization"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Advisory Status" Style="{StaticResource PersonFieldLabel}"/>
                            <ComboBox x:Name="cboTeacherAdvisoryStatus"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Style="{StaticResource PersonFieldGroup}">
                            <TextBlock Text="Employment Status" Style="{StaticResource PersonFieldLabel}"/>
                            <ComboBox x:Name="cboTeacherEmploymentStatus"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hire Date" Style="{StaticResource PersonFieldLabel}"/>
                            <DatePicker x:Name="dpTeacherHireDate"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Status" Style="{StaticResource PersonFieldLabel}"/>
                            <ComboBox x:Name="cboTeacherStatus"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="5" Style="{StaticResource DialogActionBar}" LastChildFill="False">
                <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnCreate" Content="Create Teacher" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnClear" Content="Clear" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
