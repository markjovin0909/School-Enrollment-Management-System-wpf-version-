<Window x:Class="School_Management_System.Views.DatabaseConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Settings"
        Width="1160"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock Text="Database Configuration" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock Text="Configure environment connection strings, validate them, and choose the active runtime target."
                           Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" x:Name="statusBanner" Style="{StaticResource InfoBanner}" Margin="0,0,0,12">
            <TextBlock x:Name="txtStatus" TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSection}">
            <DockPanel>
                <Button x:Name="btnValidate" Content="Test Connection" Width="122" Style="{StaticResource GhostButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <TextBlock Text="Active Environment" Style="{StaticResource Text.CaptionStrong}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox x:Name="cmbEnvironment" Width="220"/>
            </DockPanel>
        </Border>

        <GroupBox Grid.Row="3" Header="DbLocal (Localhost)" Margin="0,0,0,12">
            <TextBox x:Name="txtLocal" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="DbRemote (Remote Network)" Margin="0,0,0,12">
            <TextBox x:Name="txtRemote" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="DbOnline (Cloud)">
            <TextBox x:Name="txtOnline" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </GroupBox>

        <DockPanel Grid.Row="6" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnClose" Content="Close" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnSave" Content="Save Configuration" Width="152" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
