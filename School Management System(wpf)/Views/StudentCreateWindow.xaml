<Window x:Class="School_Management_System.Views.StudentCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Student"
        Width="840"
        Height="720"
        MinWidth="720"
        MinHeight="620"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="CompactField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="NarrowField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="280"/>
            </Style>
            <Style x:Key="WideField" TargetType="FrameworkElement" BasedOn="{StaticResource CompactField}">
                <Setter Property="Width" Value="360"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource DialogRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource DialogShell}">
                <StackPanel>
                    <TextBlock x:Name="txtDialogTitle" Text="Create Student" Style="{StaticResource DialogHeaderTitle}"/>
                    <TextBlock x:Name="txtDialogSubtitle" Text="Create a new student record in a dedicated form, then let the managed account be generated automatically in the background."
                               Style="{StaticResource DialogHeaderSubtitle}"/>
                </StackPanel>
            </Border>

            <Border x:Name="validationSummaryHost"
                    Grid.Row="1"
                    Style="{StaticResource ErrorBanner}"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
                <TextBlock x:Name="txtValidationSummary"
                           Foreground="{StaticResource Brush.Danger}"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource DialogSection}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Student Number"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="LRN"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtStudentNumber" IsReadOnly="True" Style="{StaticResource CompactField}"/>
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtStudentLrn" Style="{StaticResource MediumField}"/>

                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Content="Profile Image Path" Margin="0,12,0,0"/>
                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" x:Name="txtStudentProfileImage" Style="{StaticResource WideField}"/>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Basic Information" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="First Name"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Middle Name"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Last Name"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtStudentFirst" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtStudentMiddle" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtStudentLast" Style="{StaticResource CompactField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Birthdate" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="Sex" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="4" Content="Status" Margin="0,12,0,0"/>
                        <DatePicker Grid.Row="3" Grid.Column="0" x:Name="dpStudentBirthdate" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" x:Name="cboStudentSex" Style="{StaticResource NarrowField}"/>
                        <ComboBox Grid.Row="3" Grid.Column="4" x:Name="cboStudentStatus" Width="150" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource DialogSection}">
                <StackPanel>
                    <TextBlock Text="Contact, Guardian, and Academic Preference" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Address"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Contact Number"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" x:Name="txtStudentAddress" Style="{StaticResource WideField}"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtStudentContactNo" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Guardian Name" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="4" Content="Guardian Contact" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" x:Name="txtStudentGuardianName" Style="{StaticResource WideField}"/>
                        <TextBox Grid.Row="3" Grid.Column="4" x:Name="txtStudentGuardianContact" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Previous School" Margin="0,12,0,0"/>
                        <Label Grid.Row="4" Grid.Column="2" Content="Preferred Grade Level" Margin="0,12,0,0"/>
                        <Label Grid.Row="4" Grid.Column="4" Content="Preferred Curriculum" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="5" Grid.Column="0" x:Name="txtStudentPreviousSchool" Style="{StaticResource MediumField}"/>
                        <ComboBox Grid.Row="5" Grid.Column="2" x:Name="cboStudentPreferredGrade" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="5" Grid.Column="4" x:Name="cboStudentPreferredCurriculum" Style="{StaticResource NarrowField}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="5" Style="{StaticResource DialogActionBar}" LastChildFill="False">
                <Button x:Name="btnCancel" Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnCreate" Content="Create Student" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <Button x:Name="btnClear" Content="Clear" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Grid>
    </ScrollViewer>
</Window>
