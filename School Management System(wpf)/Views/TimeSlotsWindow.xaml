<Window x:Class="School_Management_System.Views.TimeSlotsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Time Slots"
        Width="1060" Height="660"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.45*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Time Slots"
                                Subtitle="Define bell periods, intervals, and schedule ordering"
                                Margin="0,0,0,10"/>

        <Border x:Name="searchPanel" Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8" Padding="10">
            <DockPanel>
                <Button x:Name="btnNew" Content="New Time Slot" Width="116" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                <Button x:Name="btnListEdit" Content="Edit" Width="80" DockPanel.Dock="Left" Margin="0,0,8,0" Style="{StaticResource EditActionButton}"/>
                <Button x:Name="btnListDelete" Content="Delete" Width="80" DockPanel.Dock="Left" Margin="0,0,8,0" Style="{StaticResource DeleteActionButton}"/>
                <Button x:Name="btnRefresh" Content="Refresh" Width="80" DockPanel.Dock="Right" Style="{StaticResource RefreshActionButton}"/>
                <DockPanel Margin="0,0,8,0">
                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtSearch" Width="280"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <Border x:Name="listPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Time Slot Registry"
                           Style="{StaticResource Text.SectionTitle}"
                           Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1"
                          x:Name="gridTimeSlots"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="editorPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <controls:SectionHeader Title="Time Slot Details" Subtitle="Start/end windows, ordering, and period flags" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Code"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Name"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Sort Order"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtCode" Style="{StaticResource NarrowField}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtName" Style="{StaticResource CompactField}"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtSort" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Start (HH:mm)" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="End (HH:mm)" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtStart" Style="{StaticResource NarrowField}"/>
                        <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtEnd" Style="{StaticResource NarrowField}"/>
                    </Grid>
                    <CheckBox x:Name="chkBellPeriod" Content="Bell Period" Margin="2,8,2,0"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="btnAdd" Content="Create" Width="90"/>
                        <Button x:Name="btnSave" Content="Save" Width="90"/>
                        <Button x:Name="btnDelete" Content="Delete" Width="80" Style="{StaticResource DeleteActionButton}"/>
                        <Button x:Name="btnClear" Content="Clear" Width="80" Style="{StaticResource CancelActionButton}"/>
                        <Button x:Name="btnExport" Content="Export" Width="90" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
