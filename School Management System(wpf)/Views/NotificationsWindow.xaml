<Window x:Class="School_Management_System.Views.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Notifications"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}" Margin="0,0,0,12">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource InfoBanner}"
                        Padding="12,8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="New" Style="{StaticResource Text.CaptionStrong}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtUnreadCount"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <StackPanel>
                    <TextBlock Text="New Notifications" Style="{StaticResource DialogHeaderTitle}"/>
                    <TextBlock x:Name="txtSubtitle"
                               Text="You have unread updates."
                               Style="{StaticResource DialogHeaderSubtitle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DialogSection}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Unread items for your account"
                           Style="{StaticResource Text.Subtitle}"
                           Margin="0,0,0,10"/>

                <ListBox Grid.Row="1"
                         x:Name="listNotifications"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource InfoBanner}"
                                    Margin="0,0,0,8"
                                    Padding="12,10">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding CreatedAtText}"
                                                   Style="{StaticResource Text.CaptionStrong}"
                                                   Opacity="0.75"
                                                   Margin="12,0,0,0"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Style="{StaticResource Text.CaptionStrong}"
                                                   Opacity="0.8"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,2"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="txtEmptyState"
                           Grid.Row="1"
                           Text="No new notifications."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnDismiss"
                    Content="Dismiss"
                    Width="120"
                    DockPanel.Dock="Right"
                    IsDefault="True"
                    Margin="8,0,0,0"/>
            <Button x:Name="btnMarkAllRead"
                    Content="Mark All Read"
                    Width="130"
                    Style="{StaticResource GhostButton}"
                    DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
