<Window x:Class="School_Management_System.Views.ClassOfferingEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Offering"
        Style="{StaticResource DialogWindow}"
        Width="720"
        Height="500"
        MinWidth="720"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Style="{StaticResource DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock Text="Edit Class Offering" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock Text="Assign teacher, room context, and offering state in a dedicated modal."
                           Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border x:Name="validationSummaryHost"
                Grid.Row="1"
                Style="{StaticResource ErrorBanner}"
                Visibility="Collapsed"
                Margin="0,0,0,12">
            <TextBlock x:Name="txtValidationSummary"
                       Foreground="{StaticResource Brush.Danger}"
                       TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSection}">
            <StackPanel>
                <TextBlock Text="Offering Summary" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Subject"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="Section"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtSubject" IsReadOnly="True" Style="{StaticResource MediumField}"/>
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtSection" IsReadOnly="True" Style="{StaticResource CompactField}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="School Year"/>
                    <Label Grid.Row="2" Grid.Column="2" Content="Curriculum"/>
                    <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtSchoolYear" IsReadOnly="True" Style="{StaticResource CompactField}"/>
                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtCurriculum" IsReadOnly="True" Style="{StaticResource CompactField}"/>
                </Grid>

                <TextBlock Text="Assignment" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Teacher"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="Status"/>
                    <Label Grid.Row="0" Grid.Column="4" Content="Room"/>
                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboTeacher" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource MediumField}"/>
                    <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboStatus" Style="{StaticResource NarrowField}"/>
                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="txtRoom" Style="{StaticResource NarrowField}"/>
                </Grid>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnSave" Content="Save Changes" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
        </DockPanel>
    </Grid>
</Window>
