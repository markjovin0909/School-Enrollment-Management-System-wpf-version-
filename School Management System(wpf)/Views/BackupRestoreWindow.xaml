<Window x:Class="School_Management_System.Views.BackupRestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Backup and Restore"
        Width="1200" Height="760"
        MinWidth="1020" MinHeight="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0"
                                Title="Backup and Restore"
                                Subtitle="Manage backup destinations, execute backup/restore, and review operation history"
                                Margin="0,0,0,10"/>

        <GroupBox Grid.Row="1" Header="Backup Settings" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Backup Folder" VerticalAlignment="Center" Margin="0,0,10,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtBackupFolder" Margin="0,0,10,8"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="btnBrowseBackupFolder" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="MySQL Bin Folder" VerticalAlignment="Center" Margin="0,0,10,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtMySqlBinFolder" Margin="0,0,10,8"/>
                <Button Grid.Row="1" Grid.Column="2" x:Name="btnBrowseMySqlBinFolder" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>

                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkZipCompression" Content="Compress backup as .zip" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Backup" Margin="0,0,8,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="btnBackupNow" Content="Backup Now" Width="120"/>
                        <Button x:Name="btnOpenBackupFolder" Content="Open Backup Folder" Width="150" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                    <ProgressBar Grid.Row="1" x:Name="progressBackup" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2" x:Name="lblBackupStatus" TextWrapping="Wrap" Foreground="{StaticResource BrushMuted}"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Restore" Margin="8,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtRestoreFile" Margin="0,0,10,8"/>
                        <Button Grid.Column="1" x:Name="btnBrowseRestoreFile" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>
                    </Grid>
                    <CheckBox Grid.Row="1" x:Name="chkRestoreAcknowledge" Content="I understand restore will overwrite target database data." Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Type RESTORE to enable:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtRestoreTypeConfirm" Width="180"/>
                    </StackPanel>
                    <TextBlock Grid.Row="3" x:Name="lblRestorePreflight" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{StaticResource Brush.Warning}"/>
                    <WrapPanel Grid.Row="4" Margin="0,0,0,8">
                        <Button x:Name="btnRestoreNow" Content="Restore Now" Width="120"/>
                        <Button x:Name="btnViewLog" Content="View Log" Width="110" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                    <ProgressBar Grid.Row="5" x:Name="progressRestore" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="6" x:Name="lblRestoreStatus" TextWrapping="Wrap" Foreground="{StaticResource BrushMuted}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <TextBlock Grid.Row="3" Text="Recent Backup/Restore History" FontWeight="Bold" Margin="2,0,2,8"/>
        <DataGrid Grid.Row="4" x:Name="gridHistory" IsReadOnly="True"/>
    </Grid>
</Window>
