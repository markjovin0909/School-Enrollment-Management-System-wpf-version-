<Window x:Class="School_Management_System.Views.BackupRestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Backup and Restore"
        Width="1200" Height="760"
        MinWidth="1020" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Backup and Restore"
                                Subtitle="Manage backup destinations, execute backup/restore, and review operation history"
                                Margin="0,0,0,10"/>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Backup Folder" VerticalAlignment="Center" Margin="0,0,10,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtBackupFolder" Margin="0,0,10,8"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="btnBrowseBackupFolder" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="MySQL Bin Folder" VerticalAlignment="Center" Margin="0,0,10,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtMySqlBinFolder" Margin="0,0,10,8"/>
                <Button Grid.Row="1" Grid.Column="2" x:Name="btnBrowseMySqlBinFolder" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>

                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkZipCompression" Content="Compress backup as .zip" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <controls:SectionHeader Grid.Row="0" Title="Backup Controls" Subtitle="Protect the current database state and store recoverable snapshots" Margin="0,0,0,8"/>
                        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                            <Button x:Name="btnBackupNow" Content="Backup Now" Width="120"/>
                            <Button x:Name="btnOpenBackupFolder" Content="Open Backup Folder" Width="150" Style="{StaticResource GhostButton}"/>
                        </WrapPanel>
                        <ProgressBar Grid.Row="2" x:Name="progressBackup" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" x:Name="lblBackupStatus" TextWrapping="Wrap" Foreground="{StaticResource BrushMuted}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Backup and Restore History"
                                   Style="{StaticResource Text.SectionTitle}"
                                   Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1"
                                  x:Name="gridHistory"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  ScrollViewer.CanContentScroll="True"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <controls:SectionHeader Grid.Row="0" Title="Restore Controls" Subtitle="High-risk recovery flow with preflight and typed confirmation" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Style="{StaticResource WarningBanner}" Margin="0,0,0,10">
                        <TextBlock Text="Restore overwrites target database data. Only proceed after validating the backup source and confirming downtime impact."
                                   TextWrapping="Wrap"/>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtRestoreFile" Margin="0,0,10,8"/>
                        <Button Grid.Column="1" x:Name="btnBrowseRestoreFile" Content="Browse" Width="96" Margin="0,0,0,8" Style="{StaticResource GhostButton}"/>
                    </Grid>
                    <CheckBox Grid.Row="3" x:Name="chkRestoreAcknowledge" Content="I understand restore will overwrite target database data." Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Type RESTORE to enable:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="txtRestoreTypeConfirm" Width="180"/>
                    </StackPanel>
                    <Border Grid.Row="5" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                        <TextBlock x:Name="lblRestorePreflight" TextWrapping="Wrap"/>
                    </Border>
                    <StackPanel Grid.Row="6">
                        <WrapPanel Margin="0,0,0,8">
                            <Button x:Name="btnRestoreNow" Content="Restore Now" Width="120"/>
                            <Button x:Name="btnViewLog" Content="View Log" Width="110" Style="{StaticResource GhostButton}"/>
                        </WrapPanel>
                        <ProgressBar x:Name="progressRestore" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                        <TextBlock x:Name="lblRestoreStatus" TextWrapping="Wrap" Foreground="{StaticResource BrushMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
