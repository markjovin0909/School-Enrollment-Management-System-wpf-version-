<Window x:Class="School_Management_System.Views.SubjectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Subjects"
        Width="1120" Height="680"
        MinWidth="920" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.45*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Subjects"
                                Subtitle="Maintain subject catalog records, grade-level placement, and active state"
                                Margin="0,0,0,10"/>

        <Border x:Name="searchPanel" Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8" Padding="10">
            <DockPanel>
                <Button x:Name="btnNew" Content="New Subject" Width="120" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                <Button x:Name="btnListEdit" Content="Edit" Width="80" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                <Button x:Name="btnListDelete" Content="Delete" Width="80" DockPanel.Dock="Left" Margin="0,0,8,0" Style="{StaticResource GhostButton}"/>
                <Button x:Name="btnRefresh" Content="Refresh" Width="90" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"/>
                <DockPanel Margin="0,0,8,0">
                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtSearch" Width="320"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <Border x:Name="listPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Subject Catalog" Style="{StaticResource Text.SectionTitle}" DockPanel.Dock="Left"/>
                    <TextBlock Text="Browse records without compressing the editor surface."
                               Style="{StaticResource Text.Caption}"
                               Foreground="{StaticResource BrushMuted}"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"/>
                </DockPanel>
                <DataGrid Grid.Row="1"
                          x:Name="gridSubjects"
                          IsReadOnly="True"
                          AutoGenerateColumns="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="editorPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <controls:SectionHeader Title="Subject Details"
                                            Subtitle="Edit a selected record or launch a dedicated create flow"
                                            Margin="0,0,0,10"/>

                    <Border Style="{StaticResource InfoBanner}" Margin="0,0,0,12">
                        <TextBlock Text="Use the table for browsing, keep this panel for editing, and create new records through the dedicated form."
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Identity" Style="{StaticResource Text.SectionTitle}" FontSize="16"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Code"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Title"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtCode" Style="{StaticResource NarrowField}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtTitle" Style="{StaticResource MediumField}"/>
                    </Grid>

                    <TextBlock Text="Description" Style="{StaticResource Text.SectionTitle}" FontSize="16" Margin="0,14,0,0"/>
                    <TextBox x:Name="txtDescription"
                             Height="110"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Placement" Style="{StaticResource Text.SectionTitle}" FontSize="16" Margin="0,14,0,0"/>
                    <Label Content="Grade Level" Margin="0,8,0,0"/>
                    <ComboBox x:Name="cboGradeLevel"
                              DisplayMemberPath="Code"
                              SelectedValuePath="Id"
                              Style="{StaticResource CompactField}"/>

                    <TextBlock Text="Record State" Style="{StaticResource Text.SectionTitle}" FontSize="16" Margin="0,14,0,0"/>
                    <CheckBox x:Name="chkActive" Content="Active subject" Margin="2,8,2,0"/>

                    <WrapPanel Margin="0,16,0,0">
                        <Button x:Name="btnAdd" Content="New Subject" Width="108"/>
                        <Button x:Name="btnSave" Content="Save" Width="90"/>
                        <Button x:Name="btnDelete" Content="Archive" Width="96" Style="{StaticResource GhostButton}"/>
                        <Button x:Name="btnClear" Content="Clear" Width="90" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
