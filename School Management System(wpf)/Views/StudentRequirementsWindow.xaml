<Window x:Class="School_Management_System.Views.StudentRequirementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Student Requirements"
        Width="1080" Height="680"
        MinWidth="920" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.45*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader x:Name="sectionHeader" Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Student Requirements"
                                Subtitle="Track required document submission and compliance notes"
                                Margin="0,0,0,10"/>

        <Border x:Name="toolbarPanel" Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardPanel}" Margin="0,0,0,8" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button x:Name="btnNew" Content="New Requirement" Width="124" Margin="0,0,12,0"/>
                    <TextBlock Text="Student" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboStudent" Width="420" DisplayMemberPath="Label" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock x:Name="txtSummary" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource BrushMuted}"/>
                    <Button x:Name="btnListEdit" Content="Edit Selected" Width="104" Margin="0,0,8,0" Style="{StaticResource EditActionButton}"/>
                    <Button x:Name="btnListDelete" Content="Delete Selected" Width="112" Margin="0,0,8,0" Style="{StaticResource DeleteActionButton}"/>
                    <Button x:Name="btnRefresh" Content="Refresh" Width="80" Style="{StaticResource RefreshActionButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <controls:RequirementChecklistPanel x:Name="requirementsChecklistPanel"
                                                Title="Checklist Overview"/>
        </Border>

        <Border x:Name="editorPanel" Grid.Row="2" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="8,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <controls:SectionHeader Title="Requirement Details" Subtitle="Manage submission state and notes" Margin="0,0,0,8"/>
                <Border Style="{StaticResource InfoBanner}" Margin="0,0,0,12">
                    <TextBlock Text="Select an existing checklist item to edit, or use the create flow to add a new requirement for the chosen student."
                               TextWrapping="Wrap"/>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Requirement"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="Checklist Status"/>
                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboRequirement" IsEditable="True" Style="{StaticResource MediumField}"/>
                    <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboRequirementStatus" Style="{StaticResource CompactField}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Submitted Date" Margin="0,12,0,0"/>
                    <DatePicker Grid.Row="3" Grid.Column="0" x:Name="dpSubmitted" Width="160" HorizontalAlignment="Left"/>
                </Grid>
                <Label Content="Notes" Margin="0,8,0,0"/>
                <TextBox x:Name="txtNotes" Height="190" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                <WrapPanel Margin="0,10,0,0">
                    <Button x:Name="btnAdd" Content="Create" Width="90"/>
                    <Button x:Name="btnSave" Content="Save" Width="90"/>
                    <Button x:Name="btnDelete" Content="Delete" Width="80" Style="{StaticResource DeleteActionButton}"/>
                    <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource GhostButton}" Visibility="Collapsed"/>
                </WrapPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
