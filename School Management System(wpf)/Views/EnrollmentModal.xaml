<Window x:Class="School_Management_System.Views.EnrollmentModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enroll Student"
        Width="720" Height="580"
        MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
        <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button x:Name="btnClose" Content="Cancel" Width="80" Style="{StaticResource GhostButton}" DockPanel.Dock="Right" VerticalAlignment="Top"/>
            <StackPanel>
                <TextBlock Text="Enroll Student" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="Select a student, then choose curriculum and section" Opacity="0.7" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Steps Content -->
        <Grid Grid.Row="1">
            <!-- Step 1: Select Student -->
            <Border x:Name="pnlStep1" Visibility="Visible">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,0"
                            Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtStudentSearch" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" FontSize="13"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <ListBox x:Name="lstStudents"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Opacity="0.6" FontSize="11">
                                                <Run Text="LRN: "/><Run Text="{Binding Lrn}"/>
                                                <Run Text="  |  Student No: "/><Run Text="{Binding StudentNumber}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock Grid.Row="2" x:Name="txtStep1Info" Margin="0,8,0,0" Opacity="0.5" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Step 2: Choose Curriculum and Section -->
            <Border x:Name="pnlStep2" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource InfoBanner}" Margin="0,0,0,12">
                        <TextBlock x:Name="txtSelectedStudent" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="School Year"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Curriculum"/>
                        <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboSchoolYear" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboCurriculum" Style="{StaticResource CompactField}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Grade Level"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Section"/>
                        <ComboBox Grid.Row="1" Grid.Column="0" x:Name="cboGradeLevel" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboSection" Style="{StaticResource CompactField}"/>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Available Offerings in Selected Section" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                            <DataGrid x:Name="gridOfferings"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      MaxHeight="160"
                                      HeadersVisibility="Column"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                                    <DataGridTextColumn Header="Teacher" Binding="{Binding TeacherName}" Width="150"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <DockPanel Grid.Row="4" Margin="0,12,0,0" LastChildFill="False">
                        <Button x:Name="btnBack" Content="Back" Width="90" Style="{StaticResource GhostButton}" DockPanel.Dock="Left"/>
                        <Button x:Name="btnEnroll" Content="Enroll Student" Width="130" DockPanel.Dock="Right"/>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
