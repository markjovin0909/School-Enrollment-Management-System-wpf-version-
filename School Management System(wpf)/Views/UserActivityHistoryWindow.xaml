<Window x:Class="School_Management_System.Views.UserActivityHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Activity History"
        Width="1100"
        Height="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.55*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Activity History"
                                Subtitle="Audit trail for the selected user or domain entity"
                                Margin="0,0,0,10"/>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardPanel}" Margin="0,0,0,8" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="lblViewing" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtSearch" Width="320"/>
                </StackPanel>
                <Button x:Name="btnRefresh" Content="Refresh" Width="110" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Audit Entries"
                           Style="{StaticResource Text.SectionTitle}"
                           Margin="0,0,0,10"/>
                <DataGrid x:Name="gridHistory"
                          Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="8,0,0,0">
            <StackPanel>
                <controls:SectionHeader Title="Selected Entry"
                                        Subtitle="Focused review of the chosen audit log row"
                                        Margin="0,0,0,8"/>
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,10">
                        <TextBlock Text="Date" Style="{StaticResource Text.Caption}"/>
                        <TextBlock x:Name="txtDateValue" Style="{StaticResource Text.Body}" Text="-"/>
                    </StackPanel>
                    <StackPanel Margin="8,0,0,10">
                        <TextBlock Text="Action" Style="{StaticResource Text.Caption}"/>
                        <TextBlock x:Name="txtActionValue" Style="{StaticResource Text.Body}" Text="-"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,8,10">
                        <TextBlock Text="Entity" Style="{StaticResource Text.Caption}"/>
                        <TextBlock x:Name="txtEntityValue" Style="{StaticResource Text.Body}" Text="-"/>
                    </StackPanel>
                    <StackPanel Margin="8,0,0,10">
                        <TextBlock Text="By User" Style="{StaticResource Text.Caption}"/>
                        <TextBlock x:Name="txtByUserValue" Style="{StaticResource Text.Body}" Text="-"/>
                    </StackPanel>
                </UniformGrid>
                <TextBlock Text="Details" Style="{StaticResource Text.Caption}" Margin="0,4,0,4"/>
                <TextBlock x:Name="txtDetailsValue" Style="{StaticResource Text.Body}" Text="-" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
