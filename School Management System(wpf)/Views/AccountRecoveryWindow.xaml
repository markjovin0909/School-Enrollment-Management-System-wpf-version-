<Window x:Class="School_Management_System.Views.AccountRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Recovery"
        Width="720"
        Height="640"
        MinWidth="680"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Grid Style="{StaticResource DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock Text="Recover Admin Access" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock Text="Request recovery guidance, verify the administrator identity, then set a new password."
                           Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" x:Name="recoveryStatusBanner" Style="{StaticResource InfoBanner}" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtRecoveryStatusTitle" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,2"/>
                <TextBlock x:Name="txtRecoveryStatus" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSection}">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Username / Email"/>
                    <Label Grid.Row="0" Grid.Column="1" Content="Recovery Code"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtUsername" Margin="0,0,8,12"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtIdentity" Margin="8,0,0,12"/>

                    <Label Grid.Row="2" Grid.ColumnSpan="2" Content="Verification Phrase"/>
                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtLastName" Margin="0,0,0,12"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="New Password"/>
                    <Label Grid.Row="4" Grid.Column="1" Content="Confirm Password"/>
                    <PasswordBox Grid.Row="5" Grid.Column="0" x:Name="txtNewPassword" Margin="0,0,8,0"/>
                    <PasswordBox Grid.Row="5" Grid.Column="1" x:Name="txtConfirmPassword" Margin="8,0,0,0"/>
                </Grid>

                <Border Style="{StaticResource WarningBanner}">
                    <TextBlock Text="Use the school code as the recovery code and enter SUPERADMIN as the verification phrase when validating access."
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel" Content="Cancel" Width="110" Style="{StaticResource SecondaryActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnResetPassword" Content="Reset Password" Width="126" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnVerify" Content="Verify" Width="110" Style="{StaticResource GhostButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnRequestRecovery" Content="Request Recovery" Width="136" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
