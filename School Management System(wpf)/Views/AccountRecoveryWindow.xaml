<Window x:Class="School_Management_System.Views.AccountRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Recovery"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Recover SUPERADMIN Account" FontSize="20" FontWeight="Bold" Margin="4,0,4,12"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Username"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtUsername"/>

        <Label Grid.Row="2" Grid.Column="0" Content="School Code"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtIdentity"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Last Name"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtLastName"/>

        <Label Grid.Row="4" Grid.Column="0" Content="New Password"/>
        <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="txtNewPassword"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Confirm Password"/>
        <PasswordBox Grid.Row="5" Grid.Column="1" x:Name="txtConfirmPassword"/>

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Margin="4,8,4,8" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap"
                   Text="Use School Code and set Last Name to SUPERADMIN for verification."/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnRecover" Content="Recover" Width="110"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="110" Style="{StaticResource GhostButton}"/>
        </StackPanel>
    </Grid>
</Window>
