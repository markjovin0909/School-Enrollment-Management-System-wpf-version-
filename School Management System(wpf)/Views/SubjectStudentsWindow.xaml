<Window x:Class="School_Management_System.Views.SubjectStudentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Subject Enrollees"
        Width="1120" Height="700"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="btnClose" Content="Close" Width="80" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right"/>
            <controls:SectionHeader Title="Subject Enrollees"
                                    Subtitle="Subject enrollees"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,8" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="cboSchoolYear" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="1" x:Name="cboGradeLevel" Margin="0,0,8,0" DisplayMemberPath="Code" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="2" x:Name="cboSubject" Margin="0,0,8,0" DisplayMemberPath="Label" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="3" x:Name="cboOffering" Margin="0,0,8,0" DisplayMemberPath="Label" SelectedValuePath="Id"/>
                <Button Grid.Column="4" x:Name="btnRefresh" Content="Refresh" Width="80" Style="{StaticResource RefreshActionButton}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource InfoBanner}" Margin="0,0,0,10">
                    <TextBlock x:Name="txtSummary" Text="Select a school year, subject, and offering to view enrolled students." TextWrapping="Wrap"/>
                </Border>

                <DataGrid Grid.Row="1"
                          x:Name="gridStudents"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Student No" Binding="{Binding StudentNumber}" Width="130"/>
                        <DataGridTextColumn Header="LRN" Binding="{Binding Lrn}" Width="140"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Student Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Class Status" Binding="{Binding ClassStatus}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
