<Window x:Class="School_Management_System.Views.SchoolSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Settings"
        Width="980" Height="760"
        MinWidth="860" MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0"
                                Title="School Settings"
                                Subtitle="Configure institutional defaults, enrollment windows, and numbering policy"
                                Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,4" Text="School Name"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSchoolName" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,4" Text="School Code"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSchoolCode" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,4" Text="School Address"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtAddress" Margin="0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,4" Text="Principal Name"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtPrincipal" Margin="0,4"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,12,4" Text="Enrollment Configuration"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtEnrollmentConfiguration" Margin="0,4" AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,12,4" Text="Enrollment Open Date"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                    <CheckBox x:Name="chkEnrollmentOpen" Content="Enable" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpEnrollmentOpen" Width="180"/>
                </StackPanel>

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,12,4" Text="Enrollment Close Date"/>
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                    <CheckBox x:Name="chkEnrollmentClose" Content="Enable" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpEnrollmentClose" Width="180"/>
                </StackPanel>

                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,12,4" Text="Print Header Line 1"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="txtPrintHeader1" Margin="0,4"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,8,12,4" Text="Print Header Line 2"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="txtPrintHeader2" Margin="0,4"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,8,12,4" Text="Student Number Prefix"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="txtStudentPrefix" Margin="0,4"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,8,12,4" Text="Next Student Number"/>
                <TextBox Grid.Row="10" Grid.Column="1" x:Name="txtNextStudentNo" Margin="0,4"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,8,12,4" Text="Default Section Capacity"/>
                <TextBox Grid.Row="11" Grid.Column="1" x:Name="txtDefaultCapacity" Margin="0,4"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,8,12,4" Text="Default Grade Levels"/>
                <TextBox Grid.Row="12" Grid.Column="1" x:Name="txtDefaultGradeLevels" Margin="0,4"
                         ToolTip="Comma-separated grade codes, names, or IDs (e.g., G7, G8, G9)"/>

                <TextBlock Grid.Row="13" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource BrushMuted}"
                           Text="Use grade codes/names/IDs for default grade levels."/>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="2">
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Foreground="{StaticResource BrushMuted}"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="btnReload" Content="Reload" Width="90" Style="{StaticResource GhostButton}"/>
                <Button x:Name="btnSave" Content="Save Settings" Width="120"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
