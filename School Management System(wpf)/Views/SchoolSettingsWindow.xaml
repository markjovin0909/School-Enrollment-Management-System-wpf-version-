<Window x:Class="School_Management_System.Views.SchoolSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Settings"
        Width="980" Height="760"
        MinWidth="860" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0"
                                Title="School Settings"
                                Subtitle="Configure institutional defaults, enrollment windows, and numbering policy"
                                Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="0.85*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8">
                    <StackPanel>
                        <controls:SectionHeader Title="School Profile"
                                                Subtitle="Institution identity and printed header information"
                                                Margin="0,0,0,10"/>

                        <Label Content="School Name"/>
                        <TextBox x:Name="txtSchoolName"/>

                        <Label Content="School Code" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtSchoolCode"/>

                        <Label Content="School Address" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtAddress"
                                 Height="72"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Label Content="Principal Name" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtPrincipal"/>

                        <Border Style="{StaticResource InfoBanner}" Margin="0,14,0,0">
                            <TextBlock Text="Print headers fall back to school name and address when custom lines are left blank."
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Label Content="Print Header Line 1" Margin="0,14,0,0"/>
                        <TextBox x:Name="txtPrintHeader1"/>

                        <Label Content="Print Header Line 2" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtPrintHeader2"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardPanel}" Margin="8,0,0,8">
                    <StackPanel>
                        <controls:SectionHeader Title="Enrollment Defaults"
                                                Subtitle="Calendar controls and workflow guidance"
                                                Margin="0,0,0,10"/>

                        <Label Content="Enrollment Configuration"/>
                        <TextBox x:Name="txtEnrollmentConfiguration"
                                 Height="96"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Label Content="Enrollment Open Date" Margin="0,12,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkEnrollmentOpen" Content="Enable" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <DatePicker Grid.Column="1" x:Name="dpEnrollmentOpen" Width="190" HorizontalAlignment="Left"/>
                        </Grid>

                        <Label Content="Enrollment Close Date" Margin="0,10,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkEnrollmentClose" Content="Enable" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <DatePicker Grid.Column="1" x:Name="dpEnrollmentClose" Width="190" HorizontalAlignment="Left"/>
                        </Grid>

                        <Border Style="{StaticResource WarningBanner}" Margin="0,14,0,0">
                            <TextBlock Text="If both dates are enabled, the open date must not be later than the close date."
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardPanel}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <controls:SectionHeader Title="Student Numbering"
                                                    Subtitle="Prefix and running-number settings"
                                                    Margin="0,0,0,10"/>
                            <Label Content="Student Number Prefix"/>
                            <TextBox x:Name="txtStudentPrefix" MaxWidth="220" HorizontalAlignment="Left"/>
                            <Label Content="Next Student Number" Margin="0,10,0,0"/>
                            <TextBox x:Name="txtNextStudentNo" MaxWidth="220" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0">
                            <controls:SectionHeader Title="Section Defaults"
                                                    Subtitle="Default capacity for newly created sections"
                                                    Margin="0,0,0,10"/>
                            <Label Content="Default Section Capacity"/>
                            <TextBox x:Name="txtDefaultCapacity" MaxWidth="220" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <controls:SectionHeader Title="Default Grade Scope"
                                                    Subtitle="Comma-separated grade codes, names, or numeric IDs"
                                                    Margin="0,0,0,10"/>
                            <Label Content="Default Grade Levels"/>
                            <TextBox x:Name="txtDefaultGradeLevels"
                                     ToolTip="Comma-separated grade codes, names, or IDs (e.g., G7, G8, G9)"/>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushMuted}"
                                       Text="Examples: G7, Grade 8, 12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="2">
            <Border Style="{StaticResource InfoBanner}" Padding="10,8" Margin="0,0,12,0">
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="btnReload" Content="Reload" Width="96" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                <Button x:Name="btnSave" Content="Save Settings" Width="132"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
