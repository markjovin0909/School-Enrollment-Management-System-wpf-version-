<Window x:Class="School_Management_System.Views.CurriculumMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Curriculum Mapping"
        Style="{StaticResource DialogWindow}"
        Width="720"
        Height="500"
        MinWidth="720"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/Themes/Typography.xaml"/>
                <ResourceDictionary Source="/Themes/Buttons.xaml"/>
                <ResourceDictionary Source="/Themes/Inputs.xaml"/>
                <ResourceDictionary Source="/Themes/Cards.xaml"/>
                <ResourceDictionary Source="/Themes/Dialogs.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Style="{StaticResource DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock x:Name="txtDialogTitle" Text="Add Subject Mapping" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock x:Name="txtDialogSubtitle"
                           Text="Assign a subject to a curriculum, grade level, and semester in one modal flow."
                           Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border x:Name="validationSummaryHost"
                Grid.Row="1"
                Style="{StaticResource ErrorBanner}"
                Visibility="Collapsed"
                Margin="0,0,0,12">
            <TextBlock x:Name="txtValidationSummary"
                       Foreground="{StaticResource Brush.Danger}"
                       TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSection}">
            <StackPanel>
                <TextBlock Text="Mapping Details" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Content="Curriculum"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" x:Name="txtCurriculumName" IsReadOnly="True" Style="{StaticResource MediumField}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Grade Level"/>
                    <Label Grid.Row="2" Grid.Column="2" Content="Subject"/>
                    <ComboBox Grid.Row="3" Grid.Column="0" x:Name="cboMapGrade" DisplayMemberPath="Code" SelectedValuePath="Id" Style="{StaticResource CompactField}"/>
                    <ComboBox Grid.Row="3" Grid.Column="2" x:Name="cboMapSubject" DisplayMemberPath="Label" SelectedValuePath="Id" Style="{StaticResource MediumField}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="Semester"/>
                    <Label Grid.Row="4" Grid.Column="2" Content="Required"/>
                    <ComboBox Grid.Row="5" Grid.Column="0" x:Name="cboMapSemester" Style="{StaticResource NarrowField}"/>
                    <ComboBox Grid.Row="5" Grid.Column="2" x:Name="cboMapRequired" Style="{StaticResource NarrowField}"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Sort Order"/>
                    <TextBox Grid.Column="2" x:Name="txtMapSort" Style="{StaticResource NarrowField}"/>
                </Grid>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnSave" Content="Create Mapping" Width="132" DockPanel.Dock="Right" Margin="8,0,0,0"/>
        </DockPanel>
    </Grid>
</Window>
