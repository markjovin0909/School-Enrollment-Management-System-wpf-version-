<Window x:Class="School_Management_System.Views.ReasonPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reason Required"
        Width="720"
        Height="540"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13">
    <Grid Style="{StaticResource DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock x:Name="txtTitle" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock x:Name="txtPrompt" Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource DialogSection}">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Reason Code"/>
                    <ComboBox Grid.Row="1"
                              x:Name="cboReasonCode"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Code"
                              MinWidth="300"
                              Margin="0,0,0,12"/>

                    <Label Grid.Row="2" Content="Details / Explanation"/>
                    <TextBox Grid.Row="3"
                             x:Name="txtReasonDetail"
                             MinHeight="180"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Provide relevant details. Required when reason code is OTHER."/>
                </Grid>

                <Border Style="{StaticResource WarningBanner}">
                    <TextBlock Text="Use this prompt for governed actions such as archive, restore, drop, cancel enrollment, database restore, and year-end rollover."
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ErrorBanner}" Visibility="Collapsed" x:Name="validationBanner" Margin="0,0,0,12">
            <TextBlock x:Name="txtValidation" Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"/>
        </Border>

        <DockPanel Grid.Row="3" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="110"
                    Style="{StaticResource SecondaryActionButton}"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"/>
            <Button x:Name="btnConfirm"
                    Content="Continue"
                    Width="110"
                    DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
