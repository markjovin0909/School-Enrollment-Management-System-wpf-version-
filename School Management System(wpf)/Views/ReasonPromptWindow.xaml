<Window x:Class="School_Management_System.Views.ReasonPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reason Required"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="txtTitle" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}" Margin="0,0,0,4"/>
            <TextBlock x:Name="txtPrompt" TextWrapping="Wrap" Foreground="{StaticResource Brush.TextSecondary}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Reason Code"/>
            <ComboBox x:Name="cboReasonCode"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Code"
                      MinWidth="300"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Details"/>
            <TextBox x:Name="txtReasonDetail"
                     Height="130"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     ToolTip="Provide relevant details. Required when reason code is OTHER."/>
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource ErrorBanner}" Visibility="Collapsed" x:Name="validationBanner">
            <TextBlock x:Name="txtValidation" Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"/>
        </Border>

        <DockPanel Grid.Row="4" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="110"
                    Style="{StaticResource SecondaryActionButton}"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"/>
            <Button x:Name="btnConfirm"
                    Content="Continue"
                    Width="110"
                    DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
