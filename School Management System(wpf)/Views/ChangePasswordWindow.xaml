<Window x:Class="School_Management_System.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="720"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.TextPrimary}"
        FontFamily="{DynamicResource FontFamily.Base}"
        FontSize="13">
    <Grid Style="{StaticResource DialogRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogShell}">
            <StackPanel>
                <TextBlock x:Name="txtHeaderTitle" Text="Password Update" Style="{StaticResource DialogHeaderTitle}"/>
                <TextBlock x:Name="txtHeaderSubtitle"
                           Text="Use this window to change your password or complete an administrator-triggered reset."
                           Style="{StaticResource DialogHeaderSubtitle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" x:Name="passwordStatusBanner" Style="{StaticResource InfoBanner}" Margin="0,0,0,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtPasswordStatusTitle" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,2"/>
                <TextBlock x:Name="txtPasswordStatus" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSection}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.ColumnSpan="2" x:Name="lblCurrent" Content="Current Password"/>
                    <PasswordBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="txtCurrent" Margin="0,0,0,12"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="New Password"/>
                    <Label Grid.Row="2" Grid.Column="1" Content="Confirm Password"/>
                    <PasswordBox Grid.Row="3" Grid.Column="0" x:Name="txtNew" Margin="0,0,8,0"/>
                    <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="txtConfirm" Margin="8,0,0,0"/>
                </Grid>

                <Border Style="{StaticResource InfoBanner}" Margin="0,16,0,0">
                    <TextBlock Text="Password must be at least 8 characters and include uppercase, lowercase, number, and special character."
                               Style="{StaticResource Text.Caption}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3" Style="{StaticResource DialogActionBar}" LastChildFill="False">
            <Button x:Name="btnCancel" Content="Cancel" Width="90" Style="{StaticResource CancelActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Button x:Name="btnSave" Content="Save Password" Width="128" DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
