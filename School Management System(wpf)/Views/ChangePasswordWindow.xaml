<Window x:Class="School_Management_System.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="480"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Password Update" FontSize="20" FontWeight="Bold" Margin="4,0,4,12"/>

        <Label Grid.Row="1" Grid.Column="0" x:Name="lblCurrent" Content="Current Password"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="txtCurrent"/>

        <Label Grid.Row="2" Grid.Column="0" Content="New Password"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="txtNew"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Confirm Password"/>
        <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="txtConfirm"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Margin="4,8,4,8" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap"
                   Text="Password must be at least 8 characters and include uppercase, lowercase, number, and special character."/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnSave" Content="Save" Width="110"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="110" Style="{StaticResource GhostButton}"/>
        </StackPanel>
    </Grid>
</Window>
