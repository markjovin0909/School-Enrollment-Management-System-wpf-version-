<Window x:Class="School_Management_System.Views.SectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Sections"
        Width="1240" Height="720"
        MinWidth="1040" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Legacy.BgBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="NarrowField" TargetType="FrameworkElement">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style x:Key="CompactField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="220"/>
            </Style>
            <Style x:Key="MediumField" TargetType="FrameworkElement" BasedOn="{StaticResource NarrowField}">
                <Setter Property="Width" Value="280"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.55*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="Sections"
                                Subtitle="Manage section grouping, adviser assignment, and capacity"
                                Margin="0,0,0,10"/>

        <Border x:Name="searchPanel" Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnNew" Content="New Section" Width="108" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="btnListEdit" Content="Edit" Width="80" Margin="0,0,8,0"/>
                <Button Grid.Column="2" x:Name="btnListDelete" Content="Archive/Restore" Width="120" Margin="0,0,8,0" Style="{StaticResource GhostButton}"/>
                <TextBox Grid.Column="3" x:Name="txtSearch" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="4" x:Name="cboFilterSchoolYear" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                <ComboBox Grid.Column="5" x:Name="cboFilterGrade" Margin="0,0,8,0" DisplayMemberPath="Code" SelectedValuePath="Id"/>
                <Button Grid.Column="6" x:Name="btnRefresh" Content="Refresh" Width="90" Style="{StaticResource GhostButton}"/>
            </Grid>
        </Border>

        <Border x:Name="listPanel" Grid.Row="2" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Section Registry"
                           Style="{StaticResource Text.SectionTitle}"
                           Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1"
                          x:Name="gridSections"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="editorPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <controls:SectionHeader Title="Section Details" Subtitle="Academic placement and advisory details" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Name"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="School Year"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Grade Level"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtName" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboSchoolYear" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource CompactField}"/>
                        <ComboBox Grid.Row="1" Grid.Column="4" x:Name="cboGradeLevel" DisplayMemberPath="Code" SelectedValuePath="Id" Style="{StaticResource NarrowField}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Capacity" Margin="0,12,0,0"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="Adviser" Margin="0,12,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtCapacity" Style="{StaticResource NarrowField}"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="3" x:Name="cboAdviser" DisplayMemberPath="Name" SelectedValuePath="Id" Style="{StaticResource MediumField}"/>
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="btnAdd" Content="Create" Width="90"/>
                        <Button x:Name="btnSave" Content="Save" Width="90"/>
                        <Button x:Name="btnArchiveRestore" Content="Archive/Restore" Width="130" Style="{StaticResource GhostButton}"/>
                        <Button x:Name="btnClear" Content="Clear" Width="90" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
