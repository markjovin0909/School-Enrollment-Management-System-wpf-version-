<Window x:Class="School_Management_System.Views.SchoolYearsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Years"
        Width="1180" Height="700"
        MinWidth="980" MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.45*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0" Grid.ColumnSpan="2"
                                Title="School Years"
                                Subtitle="Configure school-year windows, status, and enrollment opening dates"
                                Margin="0,0,0,10"/>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,8,8" Padding="10">
            <DockPanel>
                <Button x:Name="btnRefresh" Content="Refresh" Width="90" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
                <DockPanel Margin="0,0,8,0">
                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtSearch" Width="320"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="2" Grid.Column="0" x:Name="gridSchoolYears" IsReadOnly="True" Margin="0,0,8,0"/>

        <ScrollViewer Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <controls:SectionHeader Title="School Year Details" Subtitle="Definition dates and lifecycle controls" Margin="0,0,0,8"/>

                    <Label Content="Name"/>
                    <TextBox x:Name="txtName"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="chkStart" Content="Start Date" VerticalAlignment="Center" Width="120"/>
                        <DatePicker x:Name="dpStart" Width="170"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="chkEnd" Content="End Date" VerticalAlignment="Center" Width="120"/>
                        <DatePicker x:Name="dpEnd" Width="170"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="chkEnrollOpen" Content="Enrollment Open" VerticalAlignment="Center" Width="120"/>
                        <DatePicker x:Name="dpEnrollOpen" Width="170"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="chkEnrollClose" Content="Enrollment Close" VerticalAlignment="Center" Width="120"/>
                        <DatePicker x:Name="dpEnrollClose" Width="170"/>
                    </StackPanel>

                    <Label Content="Status" Margin="0,8,0,0"/>
                    <ComboBox x:Name="cboStatus" Width="170"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="btnAdd" Content="Add" Width="90"/>
                        <Button x:Name="btnSave" Content="Save" Width="90"/>
                        <Button x:Name="btnArchiveRestore" Content="Archive/Restore" Width="130" Style="{StaticResource GhostButton}"/>
                        <Button x:Name="btnClear" Content="Clear" Width="90" Style="{StaticResource GhostButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
