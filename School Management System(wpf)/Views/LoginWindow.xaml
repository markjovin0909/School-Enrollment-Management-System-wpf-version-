<Window x:Class="School_Management_System.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School Management System"
        Width="980"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Background="{StaticResource Brush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="28,24,16,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3" CornerRadius="18" Background="{StaticResource Brush.NavSurface}"/>

            <Image Grid.RowSpan="3"
                   Source="/Assets/Logo.jpg"
                   Width="360"
                   Height="360"
                   Stretch="Uniform"
                   Opacity="0.06"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

            <Grid Grid.Row="0" Margin="24,24,24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="266"
                        Height="266"
                        CornerRadius="40"
                        Background="#0E2038"
                        BorderBrush="#3B6298"
                        BorderThickness="2"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                </Border>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,18,0,0">
                    <TextBlock Text="Enrollment Management System"
                               Style="{StaticResource Text.PageTitle}"
                               FontSize="28"
                               Foreground="White"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <TextBlock Text="SUPERADMIN Control Portal"
                               Style="{StaticResource Text.Subtitle}"
                               Foreground="#BFD0EE"
                               Margin="0,6,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Margin="24,6,24,24" HorizontalAlignment="Center">
                <TextBlock Text="Secure administrative workspace for enrollment, staffing, reports, and operational controls."
                           Style="{StaticResource Text.Caption}"
                           Foreground="#D7E5FA"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="360"/>
                <TextBlock Text="SUPERADMIN access only."
                           Style="{StaticResource Text.CaptionStrong}"
                           Foreground="#FFD8B8"
                           Margin="0,10,0,0"
                           TextAlignment="Center"/>
                <TextBlock Text="Session and DB configuration are enforced before sign-in." Style="{StaticResource Text.Caption}" Foreground="#AFC2E0"/>
                <TextBlock Text="Use DB Settings when changing environment credentials."
                           Style="{StaticResource Text.Caption}"
                           Foreground="#AFC2E0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="16,24,28,24">
            <Border CornerRadius="16"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    Padding="24"
                    VerticalAlignment="Center"
                    MaxWidth="430">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Sign In" Style="{StaticResource Text.SectionTitle}"/>
                    <Border Grid.Row="1" Margin="0,8,0,16" Style="{StaticResource InfoBanner}">
                        <TextBlock Text="Environment: configuration-driven (Local/Remote/Online)" Style="{StaticResource Text.CaptionStrong}"/>
                    </Border>

                    <Label Grid.Row="2" Content="Username"/>
                    <TextBox Grid.Row="3" x:Name="txtUsername" Margin="0,0,0,10"/>

                    <Label Grid.Row="4" Content="Password"/>
                    <Grid Grid.Row="5" Margin="0,0,0,4">
                        <PasswordBox x:Name="pwdPassword" Height="36"/>
                        <TextBox x:Name="txtPasswordVisible" Height="36" Visibility="Collapsed"/>
                    </Grid>

                    <CheckBox Grid.Row="6" x:Name="chkShowPassword" Content="Show password" Margin="0,0,0,8"/>

                    <Border Grid.Row="7" x:Name="errorPanel" Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ErrorBanner}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=lblError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=lblError}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="lblError" Foreground="{StaticResource Brush.Danger}" TextWrapping="Wrap"/>
                    </Border>

                    <Button Grid.Row="8" x:Name="btnLogin" Content="Sign In" Height="40"/>

                    <Button Grid.Row="9" x:Name="btnForgotPassword" Content="Forgot Password" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="0,8,0,8"/>

                    <Border Grid.Row="10" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <UniformGrid Columns="2" Rows="1">
                            <Button x:Name="btnDatabaseSettings" Content="DB Settings" Style="{StaticResource GhostButton}" Margin="0,0,6,0" Height="36"/>
                            <Button x:Name="btnTestDbConnection" Content="Test Connection" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Height="36"/>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
