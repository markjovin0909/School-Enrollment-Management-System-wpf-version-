<Window x:Class="School_Management_System.Views.TeacherLoadsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="Teacher Loads"
        Width="1260" Height="720"
        MinWidth="1040" MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0"
                                Title="Teacher Loads"
                                Subtitle="Teacher assignment summary, advisory sections, and handled subjects"
                                Margin="0,0,0,10"/>

        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,8" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                    <TextBox x:Name="txtSearch" Width="280" Margin="0,0,8,0" ToolTip="Search by teacher name or employee number"/>
                    <ComboBox x:Name="cboSchoolYear" Width="190" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboTeacherStatus" Width="130"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="btnRefresh" Content="Refresh" Width="96" Style="{StaticResource GhostButton}"/>
                    <Button x:Name="btnClose" Content="Close" Width="90" Style="{StaticResource GhostButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="gridTeacherLoads" IsReadOnly="True" Margin="0,0,10,0"/>

            <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock x:Name="txtSelectHint" Text="Select a teacher from the list." Style="{StaticResource Text.SectionTitle}" Margin="0,0,0,8"/>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Teacher" Style="{StaticResource Text.Caption}"/>
                            <TextBlock x:Name="txtTeacherNameValue" Text="-" Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                        <StackPanel Margin="8,0,0,6">
                            <TextBlock Text="Employee No" Style="{StaticResource Text.Caption}"/>
                            <TextBlock x:Name="txtEmployeeNoValue" Text="-" Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Status" Style="{StaticResource Text.Caption}"/>
                            <TextBlock x:Name="txtStatusValue" Text="-" Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="Load Count" Style="{StaticResource Text.Caption}"/>
                            <TextBlock x:Name="txtLoadCountValue" Text="-" Style="{StaticResource Text.Body}"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Advisory Sections" Style="{StaticResource Text.Caption}" Margin="0,0,0,4"/>
                    <ListBox x:Name="lstAdvisory" Height="120" Margin="0,0,0,10"/>

                    <TextBlock Text="Handled Subjects" Style="{StaticResource Text.Caption}" Margin="0,0,0,4"/>
                    <ListBox x:Name="lstHandledSubjects" Height="160"/>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" x:Name="txtSummary" Margin="2,8,2,0" Foreground="{StaticResource BrushMuted}"/>
    </Grid>
</Window>
