<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- Active environment: Local, Remote, or Online -->
    <add key="ActiveEnvironment" value="Local" />
    <!-- Enrollment queue SLA visualization thresholds (in hours) -->
    <add key="EnrollmentQueueSlaWarningHours" value="24" />
    <add key="EnrollmentQueueSlaCriticalHours" value="72" />
    <add key="EnrollmentQueueSlaTrackedStatuses" value="PENDING,RESERVED" />
  </appSettings>

  <connectionStrings>
    <!-- MySQL Local Development -->
    <add name="DbLocal" 
         connectionString="server=localhost; uid=root; password=YOUR_LOCAL_PASSWORD; database=School_sms" 
         providerName="MySql.Data.MySqlClient" />
    
    <!-- MySQL Remote (Private Network) -->
    <add name="DbRemote" 
         connectionString="server=REMOTE_HOST; uid=REMOTE_USER; password=REMOTE_PASSWORD; database=School_sms" 
         providerName="MySql.Data.MySqlClient" />
    
    <!-- MySQL Online (Cloud) -->
    <add name="DbOnline" 
         connectionString="server=ONLINE_HOST; uid=ONLINE_USER; password=ONLINE_PASSWORD; database=School_sms; SslMode=Required" 
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>
