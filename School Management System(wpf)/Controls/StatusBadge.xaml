<UserControl x:Class="School_Management_System.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10"
            Padding="8,2"
            BorderThickness="1"
            BorderBrush="{Binding BadgeBorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Background="{Binding BadgeBackground, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <TextBlock Text="{Binding DisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{Binding BadgeForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Border>
</UserControl>
