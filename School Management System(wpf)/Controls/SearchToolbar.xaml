<UserControl x:Class="School_Management_System.Controls.SearchToolbar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Border Style="{StaticResource CardPanel}" Padding="12" Background="{StaticResource Brush.Surface}">
        <DockPanel LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <Button Content="{Binding SecondaryActionText, ElementName=Root}"
                        Command="{Binding SecondaryCommand, ElementName=Root}"
                        Style="{StaticResource GhostButton}"
                        Margin="0,0,8,0"
                        Visibility="{Binding ShowSecondaryAction, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Content="{Binding PrimaryActionText, ElementName=Root}"
                        Command="{Binding PrimaryCommand, ElementName=Root}"
                        Visibility="{Binding ShowPrimaryAction, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>

            <Grid MaxWidth="420">
                <TextBox Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding SearchPlaceholder, ElementName=Root}"
                         MinWidth="220"/>
                <TextBlock Text="{Binding SearchPlaceholder, ElementName=Root}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText, ElementName=Root}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchText, ElementName=Root}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
