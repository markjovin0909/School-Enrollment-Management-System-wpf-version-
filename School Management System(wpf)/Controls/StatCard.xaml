<UserControl x:Class="School_Management_System.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="160">
    <Border Style="{StaticResource CardPanel}">
        <StackPanel>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource Text.Caption}"/>
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource Text.Metric}" Margin="0,2,0,2"/>
            <TextBlock Text="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource Text.Caption}" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
