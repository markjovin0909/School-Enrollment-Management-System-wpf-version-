<UserControl x:Class="School_Management_System.Controls.RequirementChecklistPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:School_Management_System.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="{Binding Title, ElementName=Root}" Style="{StaticResource Text.SectionTitle}"/>
            <TextBlock Text="{Binding SummaryText, ElementName=Root}" Style="{StaticResource Text.Caption}" DockPanel.Dock="Right" VerticalAlignment="Bottom"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
            <TextBlock Text="{Binding HintText, ElementName=Root}" Style="{StaticResource Text.Caption}" TextWrapping="Wrap"/>
        </Border>

        <DataGrid Grid.Row="2"
                  x:Name="gridChecklist"
                  ItemsSource="{Binding Items, ElementName=Root}"
                  SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                  SelectionChanged="GridChecklist_SelectionChanged"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Requirement" Binding="{Binding RequirementName}" Width="2.1*"/>
                <DataGridTemplateColumn Header="Status" Width="1.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <controls:StatusBadge Status="{Binding StatusText}" Margin="0,2,0,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Submitted At"
                                    Binding="{Binding SubmittedAt, StringFormat={}{0:yyyy-MM-dd}}"
                                    Width="1.1*"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="1.8*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
