                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <controls:RequirementChecklistPanel x:Name="enrollRequirementChecklistPanel"
                                                                            Title="Requirement Checklist"
                                                                            HintText="Final approval requires required documents to be submitted and validated."
                                                                            Margin="0,0,0,10"/>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Submission and Updates" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
                                                <Button x:Name="btnEnrollSubmit" Content="Submit Enrollment" Style="{StaticResource WorkbenchPrimaryActionButton}"/>
                                                <Button x:Name="btnEnrollTransfer" Content="Transfer / Update" Style="{StaticResource WorkbenchSecondaryActionButton}" Margin="0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
