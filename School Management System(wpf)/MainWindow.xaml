                                            <controls:StatusBadge Status="PENDING" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="ENROLLED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="RESERVED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="CANCELLED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="DROPPED" Margin="0,0,6,6"/>
                                        </WrapPanel>

                                        <TextBlock Text="Validation Summary" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtEnrollValidationSummary" Height="220" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="{StaticResource FontFamily.Mono}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>

