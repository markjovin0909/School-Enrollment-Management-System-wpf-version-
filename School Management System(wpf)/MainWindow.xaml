<Window x:Class="School_Management_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Management System"
        Width="1500" Height="920" MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="MainShellButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>
        <Style x:Key="MainShellPrimaryButton" TargetType="Button" BasedOn="{StaticResource MainShellButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="MainShellDangerButton" TargetType="Button" BasedOn="{StaticResource MainShellButton}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground" Value="#B91C1C"/>
        </Style>
        <Style x:Key="DashboardMetroTileButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1D5E5C"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="92"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DashboardMetroInfoBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#1D5E5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>
    </Window.Resources>
    <Grid x:Name="rootShell" Background="#EEF3F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top command bar -->
            <Border x:Name="topCommandBar" Grid.Row="0" Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="0,0,0,1">
                <Grid Margin="18,14,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="#FFFFFF"
                                BorderBrush="#D7DFEA"
                                BorderThickness="1"
                                Padding="4"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="Enrollment Management System" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="txtCurrentUser" Style="{StaticResource Text.CaptionStrong}" Foreground="#475569"/>
                                <TextBlock Text="  •  " Style="{StaticResource Text.Caption}" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtCurrentEnvironment" Foreground="#2563EB" Style="{StaticResource Text.CaptionStrong}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" ItemHeight="36">
                        <Button x:Name="btnTopDashboard" Content="Dashboard" Style="{StaticResource MainShellPrimaryButton}"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="mainContentHost" Grid.Row="1" Padding="14" Background="#EEF3F9">
                <TabControl x:Name="tabsMain" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Margin" Value="0,0,2,0"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- Dashboard -->
                    <TabItem Header="Dashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <Grid>
                                <Viewbox Stretch="Fill">
                                    <Border Width="1180"
                                            Background="#0A3F3D"
                                            BorderBrush="#154A4B"
                                            BorderThickness="3">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="68"/>
                                                <RowDefinition Height="126"/>
                                                <RowDefinition Height="140"/>
                                                <RowDefinition Height="104"/>
                                                <RowDefinition Height="108"/>
                                                <RowDefinition Height="34"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Background="#194F96">
                                                <Grid Margin="26,0,26,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Border Width="54"
                                                                Height="54"
                                                                Background="#0E376F"
                                                                BorderBrush="#A3D8FF"
                                                                BorderThickness="1"
                                                                Padding="4"
                                                                Margin="0,0,16,0">
                                                            <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="SCHOOL" FontSize="13" FontWeight="Bold" Foreground="#CFEAFF"/>
                                                            <TextBlock Text="Company Profile" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Text="School Management System"
                                                               FontSize="30"
                                                               FontStyle="Italic"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right">
                                                        <TextBlock Text="Software Name"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   TextAlignment="Right"/>
                                                        <TextBlock Text="and Trademark"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   TextAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Background="#205F72">
                                                <UniformGrid Columns="12">
                                                    <Border Background="#2E7486" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#4B91A1" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#316B7F" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#5399A9" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#2A5F72" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#447E8F" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#2A5F72" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#4E95A5" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#28596B" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#4A8A9A" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#356E82" BorderBrush="#2A6476" BorderThickness="1"/>
                                                    <Border Background="#518D9D" BorderBrush="#2A6476" BorderThickness="1"/>
                                                </UniformGrid>
                                                <UniformGrid Columns="12" Opacity="0.28">
                                                    <Border Background="#FFFFFF" BorderBrush="#00000000" BorderThickness="0" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="-42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                    <Border Background="#FFFFFF" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                    <Border Background="#FFFFFF" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="-42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                    <Border Background="#FFFFFF" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                    <Border Background="#FFFFFF" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="-42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                    <Border Background="#FFFFFF" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <SkewTransform AngleX="42"/>
                                                        </Border.RenderTransform>
                                                    </Border>
                                                    <Border Background="#00000000"/>
                                                </UniformGrid>
                                            </Grid>

                                            <Grid Grid.Row="2" Background="#124C49">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.45*"/>
                                                    <ColumnDefinition Width="1.45*"/>
                                                    <ColumnDefinition Width="1.45*"/>
                                                    <ColumnDefinition Width="0.73*"/>
                                                    <ColumnDefinition Width="0.73*"/>
                                                    <ColumnDefinition Width="0.73*"/>
                                                    <ColumnDefinition Width="0.73*"/>
                                                    <ColumnDefinition Width="0.73*"/>
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="btnHubReports"
                                                        Grid.Column="0"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#39B4A9"
                                                        Foreground="White">
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="38" HorizontalAlignment="Center" Margin="0,4,0,10"/>
                                                        <TextBlock Grid.Row="1" Text="REPORTS" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="VIEW TRANSACTION REPORTS" FontSize="11" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnDashActiveStudents"
                                                        Grid.Column="1"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#3D9A94"
                                                        Foreground="White">
                                                    <Grid Margin="14,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="34" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                            <TextBlock Text="STUDENT" FontSize="11" FontWeight="Bold" Foreground="#D9F8F3" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="GRADES" FontSize="19" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="2" Text="VIEW ACADEMIC PERFORMANCE" FontSize="10" Opacity="0.9" Foreground="#D9F8F3" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnDashArchivedRecords"
                                                        Grid.Column="2"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#1E6D69"
                                                        Foreground="White">
                                                    <Grid Margin="14,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="34" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                            <TextBlock Text="ARCHIVED" FontSize="11" FontWeight="Bold" Foreground="#D8F3F0" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="RECORDS" FontSize="19" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="2" Text="ACCESS STORED FILES" FontSize="10" Opacity="0.9" Foreground="#D8F3F0" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Border Grid.Column="3"
                                                        Grid.ColumnSpan="5"
                                                        Style="{StaticResource DashboardMetroInfoBorder}"
                                                        Background="#135851">
                                                    <Grid Margin="18,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="82"
                                                                Height="82"
                                                                Background="#0D3F4A"
                                                                BorderBrush="#8ED3D0"
                                                                BorderThickness="2"
                                                                Padding="5"
                                                                Margin="0,0,16,0"
                                                                VerticalAlignment="Center">
                                                            <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="ACCOUNTS AND" FontSize="15" FontWeight="Bold" Foreground="#CFFBF5"/>
                                                            <TextBlock Text="COMPLIANCE" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                                            <TextBlock Text="Requirements, archives, and account controls" FontSize="13" Foreground="#D7F6F2" Margin="0,6,0,0"/>
                                                            <TextBlock Text="{Binding Text, ElementName=txtCurrentEnvironment}" FontSize="12" Foreground="#B6EBFF" Margin="0,8,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="3" Background="#0F4442">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Grid.ColumnSpan="3"
                                                        Style="{StaticResource DashboardMetroInfoBorder}"
                                                        Background="#103E3D">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock x:Name="txtTodayInfo"
                                                                   FontSize="18"
                                                                   Foreground="White"
                                                                   Margin="0,0,0,8"/>
                                                        <TextBlock Text="Central dashboard for admissions, records, and daily school operations"
                                                                   FontSize="16"
                                                                   Foreground="#B9E8E3"/>
                                                    </StackPanel>
                                                </Border>

                                                <Button x:Name="btnHubMasterData"
                                                        Grid.Column="3"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#4E9F8F"
                                                        Foreground="#083231">
                                                    <Grid Margin="14,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="34" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                                        <TextBlock Grid.Row="1" Text="MASTER DATA" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="YEARS, SECTIONS, CURRICULUM" FontSize="10" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnDashboardRefresh"
                                                        Grid.Column="4"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#2E8F89"
                                                        Foreground="White">
                                                    <Grid Margin="14,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="30" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                                        <TextBlock Grid.Row="1" Text="DATABASE&#x0a;CONNECTED" FontSize="18" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="REFRESH DASHBOARD" FontSize="10" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnHubMaintenance"
                                                        Grid.Column="5"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#6CC5B7"
                                                        Foreground="#0C3434">
                                                    <Grid Margin="14,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="34" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                                        <TextBlock Grid.Row="1" Text="MAINTENANCE" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="BACKUP, RESTORE, ROLLOVER" FontSize="10" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="4" Background="#114947">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Button x:Name="btnHubStudents"
                                                        Grid.Column="0"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#0E5350"
                                                        Foreground="White">
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="38" HorizontalAlignment="Center" Margin="0,4,0,10"/>
                                                        <TextBlock Grid.Row="1" Text="STUDENTS" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="MANAGE LEARNER FILES" FontSize="11" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnHubEnrollment"
                                                        Grid.Column="1"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#2D9B91"
                                                        Foreground="White">
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="38" HorizontalAlignment="Center" Margin="0,4,0,10"/>
                                                        <TextBlock Grid.Row="1" Text="ENROLLMENT" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="PROCESS APPLICATIONS" FontSize="11" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnHubTeachers"
                                                        Grid.Column="2"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#6BC3B5"
                                                        Foreground="#0C3434">
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="38" HorizontalAlignment="Center" Margin="0,4,0,10"/>
                                                        <TextBlock Grid.Row="1" Text="TEACHERS" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="FACULTY INFORMATION FILES" FontSize="11" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>

                                                <Button x:Name="btnHubScheduling"
                                                        Grid.Column="3"
                                                        Style="{StaticResource DashboardMetroTileButton}"
                                                        Background="#7C3C25"
                                                        Foreground="White">
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                                        <TextBlock Grid.Row="1" Text="SCHEDULING" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="OPEN SCHEDULING TOOLS" FontSize="10" Opacity="0.88" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Button>
                                            </Grid>

                                            <Border Grid.Row="5" Background="#E9EEF0" BorderBrush="#B8C1C8" BorderThickness="0,1,0,0">
                                                <Grid Margin="12,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Dashboard"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="#2C3B43"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Text, ElementName=txtCurrentUser}"
                                                               FontSize="13"
                                                               Foreground="#52646D"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Viewbox>
                                <Grid Visibility="Collapsed" IsHitTestVisible="False">
                                    <UniformGrid Columns="3">
                                        <controls:StatCard x:Name="cardTotalStudents" Title="Total Students" Value="0" Hint="Active student records"/>
                                        <controls:StatCard x:Name="cardEnrolledStudents" Title="Enrolled Students" Value="0" Hint="Currently enrolled learners"/>
                                        <controls:StatCard x:Name="cardPendingEnrollments" Title="Pending Enrollments" Value="0" Hint="Awaiting approval or review"/>
                                        <controls:StatCard x:Name="cardTotalTeachers" Title="Total Teachers" Value="0" Hint="Active teacher records"/>
                                        <controls:StatCard x:Name="cardAvailableSections" Title="Available Sections" Value="0" Hint="Sections with remaining capacity"/>
                                        <controls:StatCard x:Name="cardArchivedRecords" Title="Archived Records" Value="0" Hint="Non-restored archived items"/>
                                    </UniformGrid>
                                    <TextBlock x:Name="txtDashboardUpdatedAt"/>
                                    <DataGrid x:Name="gridDashboardActivity" IsReadOnly="True"/>
                                    <TextBlock x:Name="txtDashboardQueueMetric" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtDashboardReversalMetric" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtDashboardWaitlistMetric" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtDashboardCriticalOpsMetric" TextWrapping="Wrap"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Students -->
                    <TabItem Header="Students">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
