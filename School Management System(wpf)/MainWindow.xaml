                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <controls:SectionHeader Grid.Row="0"
                                                    Title="Accounts &amp; Compliance"
                                                    Subtitle="Student account lifecycle, requirement tracking, and archives in one workspace"
                                                    Margin="0,0,0,10"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="290"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Module List" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock Text="Choose one module to load the detail workspace." Style="{StaticResource Text.Caption}" Margin="0,2,0,10"/>
                                        <Button x:Name="btnOpsStudentAccounts" Content="Student Accounts" Style="{StaticResource OpsModuleButton}"/>
                                        <Button x:Name="btnOpsRequirements" Content="Student Requirements" Style="{StaticResource OpsModuleButton}"/>
                                        <Button x:Name="btnOpsArchive" Content="Archive Center" Style="{StaticResource OpsModuleButton}" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtAccountsComplianceWorkspaceInfo" Style="{StaticResource Text.Caption}"/>
                                        </Border>

                                        <Grid Grid.Row="1">
                                            <ContentControl x:Name="hostAccountsComplianceModule" Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtAccountsComplianceModulePlaceholder"
                                                       Text="Select a module from the left list to load it in this workspace."
                                                       Style="{StaticResource Text.Subtitle}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Maintenance -->
                    <TabItem Header="Maintenance">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <controls:SectionHeader Grid.Row="0"
                                                    Title="Maintenance"
                                                    Subtitle="System safeguard and year-end transition tools in one workspace"
                                                    Margin="0,0,0,10"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="290"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Module List" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock Text="Choose one module to load the detail workspace." Style="{StaticResource Text.Caption}" Margin="0,2,0,10"/>
                                        <Button x:Name="btnOpsBackup" Content="Backup / Restore" Style="{StaticResource OpsModuleButton}"/>
                                        <Button x:Name="btnOpsYearEnd" Content="Year-End Rollover" Style="{StaticResource OpsModuleButton}" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtMaintenanceWorkspaceInfo" Style="{StaticResource Text.Caption}"/>
                                        </Border>

                                        <Grid Grid.Row="1">
                                            <ContentControl x:Name="hostMaintenanceModule" Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtMaintenanceModulePlaceholder"
                                                       Text="Select a module from the left list to load it in this workspace."
                                                       Style="{StaticResource Text.Subtitle}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
