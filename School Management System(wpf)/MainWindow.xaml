                                        </Border>
                                        <DataGrid Grid.Row="2" x:Name="gridEnrollmentStudents"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,10,0,0">
