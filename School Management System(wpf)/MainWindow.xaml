                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <Label Content="Grade"/>
                                        <ComboBox x:Name="cboEnrollGrade"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <Label Content="Section"/>
                                        <ComboBox x:Name="cboEnrollSection"/>
                                    </StackPanel>
