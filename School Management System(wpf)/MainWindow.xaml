                                                <TextBlock x:Name="txtSGOfferingValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,10">
                                                <TextBlock Text="Grading Period" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGPeriodValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,10">
                                                <TextBlock Text="Student" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGStudentValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,10">
                                                <TextBlock Text="Status" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGLockStateValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,10">
                                                <TextBlock Text="Written Works" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGWrittenWorksValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,10">
                                                <TextBlock Text="Performance Tasks" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGPerformanceTasksValue" Style="{StaticResource Text.Body}" Text="-"/>
