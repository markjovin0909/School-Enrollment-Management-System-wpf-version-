                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock x:Name="txtSGSummary" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource BrushMuted}" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock Text="Grade Roster" Style="{StaticResource Text.SectionTitle}"/>
                                        </DockPanel>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridSGGrades"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  ScrollViewer.CanContentScroll="True"
                                                  VerticalAlignment="Stretch">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Student No" Binding="{Binding StudentNumber}" Width="108" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="LRN" Binding="{Binding Lrn}" Width="120" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Student" Binding="{Binding StudentName}" Width="*" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="WW" Binding="{Binding WrittenWorksText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                                                <DataGridTextColumn Header="PT" Binding="{Binding PerformanceTasksText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                                                <DataGridTextColumn Header="QA" Binding="{Binding QuarterlyAssessmentText, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                                                <DataGridTextColumn Header="Grade" Binding="{Binding QuarterGradeText}" Width="72" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedAtText}" Width="108" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Locked" Binding="{Binding LockedState}" Width="72" IsReadOnly="True"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DetailTabCard}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <controls:SectionHeader Title="Selected Grade"
                                                                    Subtitle=""
                                                                    Margin="0,0,0,6"/>
                                            <TextBlock x:Name="txtSGRosterHint"
                                                       Text="Select filters to load the roster."
                                                       Style="{StaticResource Text.Caption}"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Offering" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGOfferingValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="Grading Period" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGPeriodValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Student" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGStudentValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="Status" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGLockStateValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Written Works" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGWrittenWorksValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Performance Tasks" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGPerformanceTasksValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Quarterly Assessment" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGQuarterlyAssessmentValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Quarter Grade" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGQuarterGradeValue" Style="{StaticResource Text.Body}" Text="-" Margin="0,0,0,6"/>
                                            <TextBlock Text="Submitted / Locked" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtSGTimestampsValue" Style="{StaticResource Text.Body}" Text="-" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Teacher Details (navigated from modal) -->
                    <TabItem Header="Teacher Details">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <Button x:Name="btnTDEdit" Content="Edit" Width="80" Style="{StaticResource EditActionButton}" Margin="0,0,8,0"/>
                                    <Button x:Name="btnTDDelete" Content="Delete" Width="80" Style="{StaticResource DeleteActionButton}"/>
                                </StackPanel>
                                <controls:SectionHeader x:Name="sectionTDHeader"
                                                        Title="Teacher Details"
                                                        Subtitle="View and manage teacher information"/>
                            </DockPanel>

                            <!-- Edit Mode Banner -->
                            <Border x:Name="tdEditBanner"
                                    Grid.Row="1"
                                    Style="{StaticResource InfoBanner}"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,10">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button x:Name="btnTDSave" Content="Save Changes" Width="120" Margin="0,0,8,0"/>
                                        <Button x:Name="btnTDCancelEdit" Content="Cancel" Width="80" Style="{StaticResource CancelActionButton}"/>
                                    </StackPanel>
                                    <TextBlock Text="Edit mode — save when finished."
                                               VerticalAlignment="Center" Style="{StaticResource Text.Caption}"/>
                                </DockPanel>
                            </Border>

                            <!-- Validation Banner -->
                            <Border x:Name="tdValidationBanner"
                                    Grid.Row="1"
                                    Style="{StaticResource ErrorBanner}"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="txtTDValidation"
                                           Foreground="{StaticResource Brush.Danger}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource DetailTabCard}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Personal Information"
                                                            Subtitle="Identity, contact, and employment details"
                                                            Margin="0,0,0,6"/>
                                    <StackPanel Grid.Row="1">
                                        <Border Style="{StaticResource PersonProfileHero}" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource PersonAvatarRing}" Margin="0,0,14,0">
                                                    <TextBlock x:Name="txtTDProfileInitials" Text="TC" Style="{StaticResource PersonAvatarInitials}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock x:Name="txtTDProfileName" Text="Teacher" Style="{StaticResource PersonProfileName}"/>
                                                    <TextBlock x:Name="txtTDProfileMeta" Text="" Style="{StaticResource PersonProfileMeta}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Style="{StaticResource PersonDetailSubCard}">
                                            <StackPanel>
                                                <TextBlock Text="Identity" Style="{StaticResource PersonFormSectionTitle}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Employee No" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDEmployeeNo" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Specialization" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDSpecialization" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Status" Style="{StaticResource PersonFieldLabel}"/>
                                                        <ComboBox x:Name="cboTDStatus" IsEnabled="False" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="First Name" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDFirstName" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Last Name" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDLastName" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Middle Name" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDMiddleName" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource PersonDetailSubCard}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Contact &amp; Employment" Style="{StaticResource PersonFormSectionTitle}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Email" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDEmail" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Contact No" Style="{StaticResource PersonFieldLabel}"/>
                                                        <TextBox x:Name="txtTDContactNo" IsReadOnly="True" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" Style="{StaticResource PersonFieldGroup}">
                                                        <TextBlock Text="Employment Status" Style="{StaticResource PersonFieldLabel}"/>
                                                        <ComboBox x:Name="cboTDEmploymentStatus" IsEnabled="False" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Hire Date" Style="{StaticResource PersonFieldLabel}"/>
                                                        <DatePicker x:Name="dpTDHireDate" IsEnabled="False" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Advisory Status" Style="{StaticResource PersonFieldLabel}"/>
                                                        <ComboBox x:Name="cboTDAdvisoryStatus" IsEnabled="False" Style="{StaticResource DetailField}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DetailTabCard}" Margin="0,0,4,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0"
                                                                Title="Handled Subjects"
                                                                Subtitle="Class offerings assigned to this teacher"
                                                                Margin="0,0,0,6"/>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridTDSubjects"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  VerticalAlignment="Stretch">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                                                <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="*"/>
                                                <DataGridTextColumn Header="Grade Level" Binding="{Binding GradeLevel}" Width="100"/>
                                                <DataGridTextColumn Header="School Year" Binding="{Binding SchoolYear}" Width="100"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DetailTabCard}" Margin="4,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0"
                                                                Title="Handled Sections"
                                                                Subtitle="Double-click a section to view students"
                                                                Margin="0,0,0,6"/>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridTDSections"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  VerticalAlignment="Stretch">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="*"/>
                                                <DataGridTextColumn Header="Grade Level" Binding="{Binding GradeLevel}" Width="100"/>
                                                <DataGridTextColumn Header="School Year" Binding="{Binding SchoolYear}" Width="100"/>
                                                <DataGridTextColumn Header="Students" Binding="{Binding StudentCount}" Width="72"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Enrollment Details (navigated from modal) -->
                    <TabItem Header="Enrollment Details">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <Grid VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                <controls:SectionHeader x:Name="sectionEDHeader"
                                                        Title="Enrollment Details"
                                                        Subtitle="Student enrollment summary and class assignments"/>
                            </DockPanel>

                            <Border Grid.Row="1" Style="{StaticResource DetailTabCard}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Enrollment Summary"
                                                            Subtitle="School year, grade level, section, curriculum, and status"
                                                            Margin="0,0,0,6"/>
                                    <UniformGrid Grid.Row="1" Columns="4" Rows="2">
                                        <StackPanel Margin="0,0,12,6">
                                            <TextBlock Text="School Year" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDSchoolYear" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,6">
                                            <TextBlock Text="Grade Level" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDGradeLevel" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,6">
                                            <TextBlock Text="Section" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDSection" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Text="Curriculum" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDCurriculum" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Status" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStatus" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Enrolled At" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDEnrolledAt" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="Student" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStudentName" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,0">
                                            <TextBlock Text="LRN" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStudentLrn" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DetailTabCard}" Margin="0,0,4,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0"
                                                                Title="Student Requirements"
                                                                Subtitle="Document submission checklist for this student"
                                                                Margin="0,0,0,6"/>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridEDRequirements"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  VerticalAlignment="Stretch">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Requirement" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                                <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate}" Width="108"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DetailTabCard}" Margin="4,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0"
                                                                Title="Enrolled Subjects"
                                                                Subtitle="Class offerings in the enrolled section"
                                                                Margin="0,0,0,6"/>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridEDSubjects"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  VerticalAlignment="Stretch">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                                                <DataGridTextColumn Header="Teacher" Binding="{Binding TeacherName}" Width="*"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
