                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardPanel}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <controls:SectionHeader Title="Enrollment Workbench" Subtitle="Context-aware review and decisions with controlled transitions" Margin="0,0,0,8"/>
