                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Style="{StaticResource PersonFieldGroup}">
                                                            <TextBlock Text="Advisory Status" Style="{StaticResource PersonFieldLabel}"/>
                                                            <ComboBox x:Name="cboTeacherAdvisoryStatus"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Style="{StaticResource PersonFieldGroup}">
                                                            <TextBlock Text="Employment Status" Style="{StaticResource PersonFieldLabel}"/>
                                                            <ComboBox x:Name="cboTeacherEmploymentStatus"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Hire Date" Style="{StaticResource PersonFieldLabel}"/>
                                                            <DatePicker x:Name="dpTeacherHireDate"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Status" Style="{StaticResource PersonFieldLabel}"/>
                                                            <ComboBox x:Name="cboTeacherStatus"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Actions -->
                                            <Border Style="{StaticResource PersonActionBar}">
                                                <StackPanel>
                                                    <WrapPanel Margin="0,0,0,4">
                                                        <Button x:Name="btnTeacherAdd" Content="Add" Width="84" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8" Visibility="Collapsed"/>
                                                        <Button x:Name="btnTeacherSave" Content="Save Changes" Width="118" Margin="0,0,8,8"/>
                                                        <Button x:Name="btnTeacherClear" Content="Clear" Width="84" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                    <WrapPanel>
                                                        <Button x:Name="btnTeacherArchiveRestore" Content="Archive/Restore" Width="120" Style="{StaticResource ArchiveActionButton}" Margin="0,0,8,8"/>
                                                        <Button x:Name="btnTeacherResetPassword" Content="Reset Password" Width="128" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8"/>
                                                        <Button x:Name="btnTeacherHistory" Content="History" Width="84" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Enrollment -->
                    <TabItem Header="Enrollment">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                                <SolidColorBrush x:Key="EnrollClassicBorderBrush" Color="#B7B7B7"/>
                                <SolidColorBrush x:Key="EnrollClassicPanelBrush" Color="#F2F2F2"/>
                                <SolidColorBrush x:Key="EnrollClassicHeaderBrush" Color="#1D6F75"/>
                                <Style x:Key="EnrollClassicPanel" TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource EnrollClassicPanelBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource EnrollClassicBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="8"/>
                                </Style>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{StaticResource EnrollClassicHeaderBrush}"
                                    BorderBrush="#14555A"
                                    BorderThickness="1"
                                    Padding="12,10"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enrollment"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="18"/>
                                        <TextBlock Text="Select a student and place them into a section."
                                                   Foreground="#D9F1F3"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="btnEnrollRefresh"
                                            Grid.Column="1"
                                            Content="Refresh"
                                            Width="80"
                                            Style="{StaticResource RefreshActionButton}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource EnrollClassicPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Enrolled Student" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtEnrollTopEnrolled" Text="0" Foreground="#12565C"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="School Year" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="cboEnrollSchoolYear"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                        <TextBlock Text="Curriculum" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="cboEnrollCurriculum"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Search Student" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtEnrollSearch" ToolTip="Search by student number, LRN, or student name"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.95*"/>
                                    <ColumnDefinition Width="1.45*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource EnrollClassicPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="List Of Student" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource EnrollClassicBorderBrush}" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtEnrollmentQueueInfo" TextWrapping="Wrap"/>
                                        </Border>
                                        <DataGrid Grid.Row="2"
                                                  x:Name="gridEnrollmentStudents"
                                                  AutoGenerateColumns="True"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  BorderBrush="{StaticResource EnrollClassicBorderBrush}"
                                                  BorderThickness="1"
                                                  Background="White"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Style="{StaticResource EnrollClassicPanel}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Student Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.1*"/>
                                                    <ColumnDefinition Width="1.1*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Student Name" FontWeight="Bold" Margin="0,0,8,4"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Grade Level" FontWeight="Bold" Margin="0,0,8,4"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Curriculum" FontWeight="Bold" Margin="0,0,0,4"/>

                                                <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtEnrollReviewStudent" IsReadOnly="True" Margin="0,0,8,8"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEnrollReviewMeta" IsReadOnly="True" Margin="0,0,8,8"/>
                                                <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtEnrollRequirementSummary" IsReadOnly="True" Margin="0,0,0,8"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Status" FontWeight="Bold" Margin="0,0,8,4"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="School Year" FontWeight="Bold" Margin="0,0,8,4"/>
                                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Selected Offering" FontWeight="Bold" Margin="0,0,0,4"/>

                                                <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtEnrollReviewState" IsReadOnly="True" Margin="0,0,8,0"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtEnrollSelectedYear" IsReadOnly="True" Margin="0,0,8,0"/>
                                                <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtEnrollRecommendedSection" IsReadOnly="True" Margin="0,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Style="{StaticResource EnrollClassicPanel}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.05*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Status / Placement" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                                                <TextBlock Text="Grade Level" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cboEnrollGrade" IsEnabled="False" Margin="0,0,0,8"/>
                                                <TextBlock Text="Section" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cboEnrollSection"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                                <TextBlock Text="Placement Summary" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtEnrollPlacementSummary"
                                                         IsReadOnly="True"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         Height="88"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                                <Button x:Name="btnEnrollSubmit" Content="Enroll" Width="100" Margin="0,0,8,0" Style="{StaticResource WorkbenchPrimaryActionButton}"/>
                                                <Button x:Name="btnEnrollRefreshPlacement" Content="Refresh" Width="90" Margin="0,0,8,0" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                                <Button x:Name="btnEnrollTransfer" Content="Edit" Width="90" Margin="0,0,8,0" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                                <Button x:Name="btnEnrollCancel" Content="Cancel" Width="90" Margin="0,0,8,0" Style="{StaticResource WorkbenchDangerActionButton}"/>
                                                <Button x:Name="btnEnrollDrop" Content="Drop" Width="90" Style="{StaticResource WorkbenchDangerActionButton}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2" Style="{StaticResource EnrollClassicPanel}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Subjects" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                            <DataGrid Grid.Row="1"
                                                      x:Name="gridEnrollmentClasses"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      SelectionMode="Single"
                                                      HeadersVisibility="Column"
                                                      BorderBrush="{StaticResource EnrollClassicBorderBrush}"
                                                      BorderThickness="1"
                                                      Background="White">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Subject" Binding="{Binding SubjectDisplay}" Width="1.35*"/>
                                                    <DataGridTextColumn Header="Grade" Binding="{Binding GradeDisplay}" Width="0.85*"/>
                                                    <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="1*"/>
                                                    <DataGridTextColumn Header="Status" Binding="{Binding PlacementStatus}" Width="0.8*"/>
                                                    <DataGridTextColumn Header="Available" Binding="{Binding AvailableSeatsDisplay}" Width="0.75*"/>
                                                    <DataGridTextColumn Header="Capacity" Binding="{Binding CapacityDisplay}" Width="0.75*"/>
                                                    <DataGridTextColumn Header="Curriculum" Binding="{Binding CurriculumDisplay}" Width="1.2*"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                            <Expander Grid.Row="3"
                                      Header="Advanced Enrollment Tools"
                                      IsExpanded="False"
                                      Background="Transparent"
                                      Margin="0,10,0,0">
                                <Border Style="{StaticResource EnrollClassicPanel}">
                                    <StackPanel>
                                        <Border x:Name="enrollStaleBanner"
                                                Background="#FFF4D6"
                                                BorderBrush="#E7C76E"
                                                BorderThickness="1"
                                                Visibility="Collapsed"
                                                Margin="0,0,0,8"
                                                Padding="8">
                                            <TextBlock x:Name="txtEnrollStaleMessage" TextWrapping="Wrap"/>
                                        </Border>

                                        <WrapPanel Margin="0,0,0,8">
                                            <Button x:Name="btnEnrollApprove" Content="Approve" Width="110" Margin="0,0,8,6" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                            <Button x:Name="btnEnrollReturn" Content="Return For Correction" Width="150" Margin="0,0,8,6" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                            <Button x:Name="btnEnrollPromote" Content="Promote Waitlist" Width="130" Margin="0,0,8,6" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                            <Button x:Name="btnEnrollNextReview" Content="Next Review" Width="110" Margin="0,0,8,6" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                            <Button x:Name="btnEnrollReloadSelection" Content="Reload Selected" Width="120" Margin="0,0,8,6" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                        </WrapPanel>

                                        <DockPanel Margin="0,0,0,10">
                                            <ComboBox x:Name="cboEnrollStatusChange" Width="180" DockPanel.Dock="Left"/>
                                            <Button x:Name="btnEnrollSetStatus" Content="Apply Status" Width="110" Margin="8,0,0,0" DockPanel.Dock="Left" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                        </DockPanel>

                                        <controls:RequirementChecklistPanel x:Name="enrollRequirementChecklistPanel"
                                                                            Title="Requirement Checklist"
                                                                            HintText="Final approval requires required documents to be submitted and validated."
                                                                            Margin="0,0,0,10"/>

                                        <TextBlock Text="Validation Summary" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtEnrollValidationSummary"
                                                 Height="180"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="{StaticResource FontFamily.Mono}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Reports -->
                    <TabItem Header="Reports">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <Button x:Name="btnReportExport" Content="Export CSV" Width="110" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
                                <controls:SectionHeader Title="Reports"
                                                        Subtitle="Build and export school reports"/>
                            </DockPanel>

                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock Text="Saved Filters" Style="{StaticResource Text.SectionTitle}" DockPanel.Dock="Left"/>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                            <ComboBox x:Name="cboReportPreset" Width="220" Margin="0,0,8,0"/>
                                            <TextBox x:Name="txtReportPresetName" Width="190" Margin="0,0,8,0" ToolTip="Preset name"/>
                                            <Button x:Name="btnReportPresetApply" Content="Apply" Width="78" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                            <Button x:Name="btnReportPresetSave" Content="Save Preset" Width="108" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                            <Button x:Name="btnReportPresetDelete" Content="Delete Preset" Width="110" Style="{StaticResource DeleteActionButton}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <UniformGrid Grid.Row="2" Columns="4">
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="Report Type"/>
                                            <ComboBox x:Name="cboReportType"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="School Year"/>
                                            <ComboBox x:Name="cboReportSchoolYear"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="Grade"/>
                                            <ComboBox x:Name="cboReportGrade"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <Label Content="Section"/>
                                            <ComboBox x:Name="cboReportSection"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Status"/>
                                            <ComboBox x:Name="cboReportStatus"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Student"/>
                                            <ComboBox x:Name="cboReportStudent"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Actions"/>
                                            <WrapPanel>
                                                <Button x:Name="btnReportLoad" Content="Load Report" Width="120" Margin="0,0,8,0"/>
                                                <Button x:Name="btnReportHistoryRefresh" Content="Refresh History" Width="128" Style="{StaticResource GhostButton}"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.55*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0" Title="Report Results" Subtitle="" Margin="0,0,0,8"/>
                                        <DataGrid Grid.Row="1"
                                                  x:Name="gridReports"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  ScrollViewer.CanContentScroll="True"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}" Margin="10,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <controls:SectionHeader Grid.Row="0" Title="Run History" Subtitle="" Margin="0,0,0,8"/>
                                        <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,10">
                                            <TextBlock x:Name="txtReportRunHistorySummary" Text="Run history" Style="{StaticResource Text.CaptionStrong}" TextWrapping="Wrap"/>
                                        </Border>
                                        <DataGrid Grid.Row="2"
                                                  x:Name="gridReportRunHistory"
                                                  IsReadOnly="True"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  ScrollViewer.CanContentScroll="True"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Master Data -->
                    <TabItem Header="Master Data">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <Grid Margin="0,0,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="560"/>
                            </Grid.RowDefinitions>

                            <controls:SectionHeader Grid.Row="0"
                                                    Title="Master Data"
                                                    Subtitle="School settings and academic structure"
                                                    Margin="0,0,0,10"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="248"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left module sidebar -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource CardPanel}"
                                        Margin="0,0,12,0"
                                        Padding="12">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="Modules"
                                                   Style="{StaticResource Text.CaptionStrong}"
                                                   FontSize="14"
                                                   Foreground="#1E3A5F"
                                                   Margin="0,0,0,10"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <Button x:Name="btnOpsSchoolSettings" Content="School Settings" Style="{StaticResource OpsModuleButton}"/>
                                                <Button x:Name="btnOpsSchoolYears" Content="School Years" Style="{StaticResource OpsModuleButton}"/>
                                                <Button x:Name="btnOpsGradeLevels" Content="Grade Levels" Style="{StaticResource OpsModuleButton}"/>
                                                <Button x:Name="btnOpsSubjects" Content="Subjects" Style="{StaticResource OpsModuleButton}"/>
                                                <Button x:Name="btnOpsCurriculum" Content="Curriculum" Style="{StaticResource OpsModuleButton}"/>
                                                <Button x:Name="btnOpsSections" Content="Sections" Style="{StaticResource OpsModuleButton}" Margin="0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <!-- Right workspace -->
                                <Border Grid.Column="1" Style="{StaticResource CardPanel}" MinWidth="480" Padding="12">
                                    <Grid>
                                        <ContentControl x:Name="hostMasterDataModule" Visibility="Collapsed"/>
                                        <TextBlock x:Name="txtMasterDataModulePlaceholder"
                                                   Text="Select a module from the sidebar."
                                                   Style="{StaticResource Text.Subtitle}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>
                                        <TextBlock x:Name="txtMasterDataWorkspaceInfo" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Scheduling -->
                    <TabItem Header="Scheduling">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <Grid Margin="0,0,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="560"/>
                            </Grid.RowDefinitions>

                            <controls:SectionHeader Grid.Row="0"
                                                    Title="Scheduling"
                                                    Subtitle="Class offerings, schedules, and facilities"
                                                    Margin="0,0,0,10"/>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="248"/>
                                    <ColumnDefinition Width="*"/>
