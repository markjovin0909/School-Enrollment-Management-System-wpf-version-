                                            <StackPanel Margin="0,0,8,10">
                                                <TextBlock Text="Quarterly Assessment" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGQuarterlyAssessmentValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,10">
                                                <TextBlock Text="Quarter Grade" Style="{StaticResource Text.Caption}"/>
                                                <TextBlock x:Name="txtSGQuarterGradeValue" Style="{StaticResource Text.Body}" Text="-"/>
                                            </StackPanel>
                                        </UniformGrid>

