<Window x:Class="School_Management_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Management System"
        Width="1500" Height="920" MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Background="{StaticResource Brush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation rail -->
        <Border Grid.Column="0" BorderBrush="{StaticResource Brush.NavRailBorder}" BorderThickness="0,0,1,0" Padding="18,20,18,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource Color.NavSurface}" Offset="0"/>
                    <GradientStop Color="{StaticResource Color.NavSurfaceAlt}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="EMS" FontSize="34" FontWeight="Bold" Foreground="#F3F8FF"/>
                    <TextBlock Text="SUPERADMIN PORTAL" Style="{StaticResource NavSectionLabel}" Margin="0,2,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Background="#112E50" BorderBrush="#2B5687" Margin="0,0,0,16">
                    <TextBlock Text="Enrollment, staffing, reports, and administration" Foreground="#DDE8FA" TextWrapping="Wrap" FontSize="12"/>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button x:Name="btnNavDashboard" Content="Dashboard" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavStudents" Content="Students" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavTeachers" Content="Teachers" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavEnrollment" Content="Enrollment" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavReports" Content="Reports" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavMasterData" Content="Master Data" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavScheduling" Content="Scheduling" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavAccountsCompliance" Content="Accounts &amp; Compliance" Style="{StaticResource SideNavButton}"/>
                        <Button x:Name="btnNavMaintenance" Content="Maintenance" Style="{StaticResource SideNavButton}"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" Style="{StaticResource InfoBanner}" Background="#102747" BorderBrush="#294C78" Margin="0,16,0,0">
                    <TextBlock Text="Backend parity is preserved while the desktop UX is modernized for faster admin workflows." Foreground="#C7D9F0" TextWrapping="Wrap" FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <!-- Workspace -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top command bar -->
            <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,18,0">
                        <TextBlock Text="Enrollment Management System" FontSize="20" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock x:Name="txtCurrentUser" Style="{StaticResource Text.CaptionStrong}"/>
                            <TextBlock Text="  •  " Style="{StaticResource Text.Caption}"/>
                            <TextBlock x:Name="txtCurrentEnvironment" Foreground="{StaticResource Brush.Info}" Style="{StaticResource Text.CaptionStrong}"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" ItemHeight="34">
                        <Button x:Name="btnTopDbSettings" Content="DB Settings" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                        <Button x:Name="btnTopChangePassword" Content="Change Password" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                        <Button x:Name="btnTopActivity" Content="Activity History" Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                        <Button x:Name="btnTopLogout" Content="Logout" Style="{StaticResource DangerGhostButton}"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="18,16,18,18" Background="{StaticResource Brush.Background}">
                <TabControl x:Name="tabsMain">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- Dashboard -->
                    <TabItem Header="Dashboard">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Dashboard" Style="{StaticResource Text.PageTitle}"/>
                                    <TextBlock Text="Live enrollment, staffing, and operational graph overview" Style="{StaticResource Text.Subtitle}"/>
                                </StackPanel>

                                <Button x:Name="btnDashboardRefresh"
                                        Grid.Column="1"
                                        Content="Refresh"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource PageActionButton}"/>
                            </Grid>

                            <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,12">
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Students" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardStudents" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Teachers" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardTeachers" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Sections" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardSections" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Offerings" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardOfferings" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0"><StackPanel><TextBlock Text="Enrolled" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardEnrolled" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardPanel}"><StackPanel><TextBlock Text="Pending" Style="{StaticResource Text.Caption}"/><TextBlock x:Name="cardPending" Style="{StaticResource Text.Metric}"/></StackPanel></Border>
                            </UniformGrid>

                            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,12">
                                <Border Style="{StaticResource WarningBanner}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Requirement Alerts" Style="{StaticResource Text.CaptionStrong}" Foreground="{StaticResource Brush.Warning}"/>
                                        <TextBlock x:Name="txtDashboardRequirementsWarning" Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InfoBanner}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Waitlist Pressure" Style="{StaticResource Text.CaptionStrong}" Foreground="{StaticResource Brush.Info}"/>
                                        <TextBlock x:Name="txtDashboardWaitlistWarning" Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource ErrorBanner}">
                                    <StackPanel>
                                        <TextBlock Text="Backup / Restore Health" Style="{StaticResource Text.CaptionStrong}" Foreground="{StaticResource Brush.Danger}"/>
                                        <TextBlock x:Name="txtDashboardBackupWarning" Style="{StaticResource Text.Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,12">
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Queue Aging" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock x:Name="txtMetricQueueAgingValue" Style="{StaticResource Text.Metric}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="txtMetricQueueAgingTrend" Style="{StaticResource Text.Caption}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Decision Reversals" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock x:Name="txtMetricDecisionReversalsValue" Style="{StaticResource Text.Metric}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="txtMetricDecisionReversalsTrend" Style="{StaticResource Text.Caption}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Waitlist Pressure" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock x:Name="txtMetricWaitlistPressureValue" Style="{StaticResource Text.Metric}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="txtMetricWaitlistPressureTrend" Style="{StaticResource Text.Caption}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardPanel}">
                                    <StackPanel>
                                        <TextBlock Text="Failed Critical Ops" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock x:Name="txtMetricFailedOpsValue" Style="{StaticResource Text.Metric}" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="txtMetricFailedOpsTrend" Style="{StaticResource Text.Caption}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Enrollment Status Chart" Style="{StaticResource Text.SectionTitle}" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="1" Text="Current distribution across active enrollment states." Style="{StaticResource Text.Caption}" Margin="0,0,0,14"/>

                                        <Border Grid.Row="2"
                                                Height="220"
                                                Background="{StaticResource Brush.SurfaceAlt}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="18">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" x:Name="txtDashboardEnrollmentTotal" FontSize="30" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Text="Total active enrollment states tracked" Style="{StaticResource Text.Caption}" Margin="0,2,0,18"/>

                                                <Border Grid.Row="2"
                                                        Height="50"
                                                        CornerRadius="10"
                                                        BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="1"
                                                        Background="White"
                                                        Padding="0"
                                                        Margin="0,0,0,18">
                                                    <Grid x:Name="gridDashboardEnrollmentSegments" ClipToBounds="True"/>
                                                </Border>

                                                <ItemsControl Grid.Row="3" x:Name="itemsDashboardEnrollmentLegend">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="14"
                                                                        Height="14"
                                                                        CornerRadius="3"
                                                                        Background="{Binding Fill}"
                                                                        Margin="0,2,10,0"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Label}" Style="{StaticResource Text.CaptionStrong}"/>
                                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource Text.Caption}"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding PercentageLabel}"
                                                                           Style="{StaticResource Text.CaptionStrong}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="12,0,0,0"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="Operational Metrics Chart" Style="{StaticResource Text.SectionTitle}" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="1" Text="Current signal strength by operational metric." Style="{StaticResource Text.Caption}" Margin="0,0,0,14"/>

                                        <Border Grid.Row="2"
                                                Height="220"
                                                Background="{StaticResource Brush.SurfaceAlt}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="18">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <ItemsControl Grid.Row="0" x:Name="itemsDashboardMetricBars" VerticalAlignment="Stretch">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="8,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0"
                                                                           Text="{Binding ValueLabel}"
                                                                           Style="{StaticResource Text.CaptionStrong}"
                                                                           HorizontalAlignment="Center"
                                                                           Margin="0,0,0,8"/>
                                                                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                                                                    <Border Width="52"
                                                                            Height="150"
                                                                            Background="White"
                                                                            BorderBrush="{StaticResource Brush.Border}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Bottom"/>
                                                                    <Border Width="52"
                                                                            Height="{Binding ColumnHeight}"
                                                                            Background="{Binding Fill}"
                                                                            CornerRadius="10,10,10,10"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Bottom"/>
                                                                </Grid>
                                                                <TextBlock Grid.Row="2"
                                                                           Text="{Binding Label}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource Text.CaptionStrong}"
                                                                           Margin="0,10,0,0"/>
                                                                <TextBlock Grid.Row="3"
                                                                           Text="{Binding Trend}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource Text.Caption}"
                                                                           Margin="0,4,0,0"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Grid.Row="1"
                                                           Text="Scale: relative within the current dashboard snapshot"
                                                           Style="{StaticResource Text.Caption}"
                                                           HorizontalAlignment="Right"
                                                           Margin="0,12,0,0"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- Students -->
                    <TabItem Header="Students">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <Button x:Name="btnStudentsRefresh" Content="Refresh" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
                                <controls:SectionHeader Title="Students"
                                                        Subtitle="Manage student identity records, linked accounts, and status"/>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.55*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <DockPanel>
                                                <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                                                <TextBox x:Name="txtStudentSearch" Width="340" VerticalAlignment="Center" ToolTip="Search by Student No, LRN, Account ID, Name, or Status"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtStudentsWorkspaceInfo" Style="{StaticResource Text.Caption}"/>
                                        </Border>
                                        <DataGrid Grid.Row="2" x:Name="gridStudents"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <controls:SectionHeader Title="Student Details" Subtitle="Identity, profile, preferences, and account lifecycle controls" Margin="0,0,0,8"/>

                                            <Border x:Name="studentValidationSummaryHost"
                                                    Style="{StaticResource ErrorBanner}"
                                                    Visibility="Collapsed"
                                                    Margin="0,0,0,10">
                                                <TextBlock x:Name="txtStudentValidationSummary"
                                                           Foreground="{StaticResource Brush.Danger}"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <Border Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Student Number"/>
                                                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="txtStudentNumber" IsReadOnly="True" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="2" Grid.ColumnSpan="2" Content="LRN"/>
                                                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtStudentLrn" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="4" Grid.ColumnSpan="2" Content="Profile Image Path"/>
                                                    <TextBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="txtStudentProfileImage"/>
                                                </Grid>
                                            </Border>

                                            <Border Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Row="0" Grid.Column="0" Content="First Name"/>
                                                    <Label Grid.Row="0" Grid.Column="1" Content="Last Name"/>
                                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtStudentFirst" Margin="0,0,6,8"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtStudentLast" Margin="6,0,0,8"/>

                                                    <Label Grid.Row="2" Grid.ColumnSpan="2" Content="Middle Name"/>
                                                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtStudentMiddle" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="4" Grid.Column="0" Content="Birthdate"/>
                                                    <Label Grid.Row="4" Grid.Column="1" Content="Sex"/>
                                                    <DatePicker Grid.Row="5" Grid.Column="0" x:Name="dpStudentBirthdate" Margin="0,0,6,8"/>
                                                    <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cboStudentSex" Margin="6,0,0,8"/>

                                                    <Label Grid.Row="6" Grid.ColumnSpan="2" Content="Status"/>
                                                    <ComboBox Grid.Row="7" Grid.ColumnSpan="2" x:Name="cboStudentStatus"/>
                                                </Grid>
                                            </Border>

                                            <Border Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Row="0" Grid.Column="0" Content="Address"/>
                                                    <Label Grid.Row="0" Grid.Column="1" Content="Contact No"/>
                                                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtStudentAddress" Margin="0,0,6,8"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtStudentContactNo" Margin="6,0,0,8"/>

                                                    <Label Grid.Row="2" Grid.Column="0" Content="Guardian Name"/>
                                                    <Label Grid.Row="2" Grid.Column="1" Content="Guardian Contact"/>
                                                    <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtStudentGuardianName" Margin="0,0,6,8"/>
                                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtStudentGuardianContact" Margin="6,0,0,8"/>

                                                    <Label Grid.Row="4" Grid.ColumnSpan="2" Content="Previous School"/>
                                                    <TextBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="txtStudentPreviousSchool" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="6" Grid.Column="0" Content="Preferred Grade"/>
                                                    <Label Grid.Row="6" Grid.Column="1" Content="Preferred Curriculum"/>
                                                    <ComboBox Grid.Row="7" Grid.Column="0" x:Name="cboStudentPreferredGrade" Margin="0,0,6,0"/>
                                                    <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cboStudentPreferredCurriculum" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>

                                            <WrapPanel>
                                                <Button x:Name="btnStudentAdd" Content="Add" Width="84" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8"/>
                                                <Button x:Name="btnStudentSave" Content="Save" Width="84" Margin="0,0,8,8"/>
                                                <Button x:Name="btnStudentArchiveRestore" Content="Archive/Restore" Width="128" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,8"/>
