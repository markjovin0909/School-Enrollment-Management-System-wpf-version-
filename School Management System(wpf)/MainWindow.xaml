                                                    <Button x:Name="btnEnrollNextReview" Content="Next Review Item" Width="132" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,6"/>
                                                    <Button x:Name="btnEnrollReloadSelection" Content="Reload Selected" Width="124" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,6"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <controls:RequirementChecklistPanel x:Name="enrollRequirementChecklistPanel"
                                                                            Title="Requirement Checklist"
                                                                            HintText="Final approval requires required documents to be submitted and validated."
                                                                            Margin="0,0,0,10"/>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Submission and Updates" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
                                                <Button x:Name="btnEnrollSubmit" Content="Submit Enrollment" Style="{StaticResource WorkbenchPrimaryActionButton}"/>
                                                <Button x:Name="btnEnrollTransfer" Content="Transfer / Update" Style="{StaticResource WorkbenchSecondaryActionButton}" Margin="0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Review Decisions" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
                                                <Button x:Name="btnEnrollApprove" Content="Approve" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                                <Button x:Name="btnEnrollReturn" Content="Return for Correction" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                                <Button x:Name="btnEnrollPromote" Content="Promote Waitlist" Style="{StaticResource WorkbenchSecondaryActionButton}" Margin="0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Destructive Actions" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
                                                <Button x:Name="btnEnrollCancel" Content="Cancel Enrollment" Style="{StaticResource WorkbenchDangerActionButton}"/>
                                                <Button x:Name="btnEnrollDrop" Content="Drop" Style="{StaticResource WorkbenchDangerActionButton}" Margin="0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Explicit Status Transition" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
                                                <DockPanel Margin="0,0,0,2">
                                                    <ComboBox x:Name="cboEnrollStatusChange" Width="180" DockPanel.Dock="Left"/>
                                                    <Button x:Name="btnEnrollSetStatus" Content="Apply" Width="92" Style="{StaticResource WorkbenchSecondaryActionButton}" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Status Legend" Style="{StaticResource Text.CaptionStrong}" Margin="0,2,0,4"/>
                                        <WrapPanel Margin="0,0,0,8">
                                            <controls:StatusBadge Status="PENDING" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="ENROLLED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="RESERVED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="CANCELLED" Margin="0,0,6,6"/>
                                            <controls:StatusBadge Status="DROPPED" Margin="0,0,6,6"/>
                                        </WrapPanel>

                                        <TextBlock Text="Validation Summary" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtEnrollValidationSummary" Height="220" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="{StaticResource FontFamily.Mono}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

