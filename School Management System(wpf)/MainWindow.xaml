                                                <Button x:Name="btnEnrollReturn" Content="Return for Correction" Style="{StaticResource WorkbenchSecondaryActionButton}"/>
                                                <Button x:Name="btnEnrollPromote" Content="Promote Waitlist" Style="{StaticResource WorkbenchSecondaryActionButton}" Margin="0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Background="{StaticResource Brush.SurfaceAlt}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Destructive Actions" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,6"/>
