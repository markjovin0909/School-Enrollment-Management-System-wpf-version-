<Window x:Class="School_Management_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:School_Management_System.Controls"
        Title="School Management System"
        Width="1500" Height="920" MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="MainShellButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>
        <Style x:Key="MainShellPrimaryButton" TargetType="Button" BasedOn="{StaticResource MainShellButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="MainShellDangerButton" TargetType="Button" BasedOn="{StaticResource MainShellButton}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground" Value="#B91C1C"/>
        </Style>
    </Window.Resources>
    <Grid Background="#EEF3F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top command bar -->
            <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="0,0,0,1">
                <Grid Margin="18,14,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="12"
                                Background="#FFFFFF"
                                BorderBrush="#D7DFEA"
                                BorderThickness="1"
                                Padding="4"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock Text="Enrollment Management System" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="txtCurrentUser" Style="{StaticResource Text.CaptionStrong}" Foreground="#475569"/>
                                <TextBlock Text="  •  " Style="{StaticResource Text.Caption}" Foreground="#94A3B8"/>
                                <TextBlock x:Name="txtCurrentEnvironment" Foreground="#2563EB" Style="{StaticResource Text.CaptionStrong}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" ItemHeight="36">
                        <Button x:Name="btnTopDashboard" Content="Dashboard" Style="{StaticResource MainShellPrimaryButton}"/>
                        <Button x:Name="btnTopDbSettings" Content="DB Settings" Style="{StaticResource MainShellButton}"/>
                        <Button x:Name="btnTopChangePassword" Content="Change Password" Style="{StaticResource MainShellButton}"/>
                        <Button x:Name="btnTopActivity" Content="Activity History" Style="{StaticResource MainShellButton}"/>
                        <Button x:Name="btnTopLogout" Content="Logout" Style="{StaticResource MainShellDangerButton}" Margin="0"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="14" Background="#EEF3F9">
                <TabControl x:Name="tabsMain">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Margin" Value="0,0,2,0"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <!-- Dashboard -->
                    <TabItem Header="Dashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <Border Margin="0,0,0,14"
                                        CornerRadius="22"
                                        Padding="0"
                                        BorderBrush="#4E9ED3"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#113E78" Offset="0"/>
                                            <GradientStop Color="#11626C" Offset="0.58"/>
                                            <GradientStop Color="#1798A0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="52"/>
                                            <RowDefinition Height="34"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" CornerRadius="22,22,0,0" Background="#154987">
                                            <Grid Margin="24,0,24,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="School Management System"
                                                           Foreground="White"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Text, ElementName=txtCurrentEnvironment}"
                                                           Foreground="#D8F6FF"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <UniformGrid Grid.Row="1" Columns="12">
                                            <Border Background="#2A617F"/>
                                            <Border Background="#3A7B97"/>
                                            <Border Background="#2F6D89"/>
                                            <Border Background="#497E98"/>
                                            <Border Background="#235770"/>
                                            <Border Background="#3F7086"/>
                                            <Border Background="#2A617F"/>
                                            <Border Background="#4A839C"/>
                                            <Border Background="#25566C"/>
                                            <Border Background="#3A7B97"/>
                                            <Border Background="#2F6D89"/>
                                            <Border Background="#497E98"/>
                                        </UniformGrid>

                                        <Grid Grid.Row="2" Margin="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                Width="126"
                                                Height="126"
                                                CornerRadius="28"
                                                Background="#0C284A"
                                                BorderBrush="#7FD2F0"
                                                BorderThickness="2"
                                                Padding="12"
                                                Margin="0,0,20,0">
                                            <Image Source="/Assets/Logo.jpg" Stretch="Uniform"/>
                                        </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="txtTodayInfo"
                                                           Style="{StaticResource Text.CaptionStrong}"
                                                           Foreground="#D8F6FF"
                                                           Margin="0,0,0,6"/>
                                                <TextBlock Text="School Enrollment Management System"
                                                           Style="{StaticResource Text.PageTitle}"
                                                           FontSize="30"
                                                           Foreground="White"/>
                                                <TextBlock Text="Central operations dashboard for enrollment, records, reports, and administration"
                                                           Style="{StaticResource Text.Subtitle}"
                                                           Foreground="#D9F0FF"
                                                           Margin="0,8,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <Border Style="{StaticResource InfoBanner}" Background="#144D73" BorderBrush="#7BC9E8" Padding="10,8" Margin="0,0,10,0">
                                                        <TextBlock Text="School profile, identity, and branding" Foreground="#F1FBFF"/>
                                                    </Border>
                                                    <Border Style="{StaticResource InfoBanner}" Background="#154E45" BorderBrush="#6FD6C4" Padding="10,8">
                                                        <TextBlock Text="Centralized records and enrollment control" Foreground="#EDFFFB"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="Academic Operations" FontSize="28" FontWeight="SemiBold" Foreground="White" TextAlignment="Right"/>
                                                <TextBlock Text="Command Center" FontSize="28" FontWeight="SemiBold" Foreground="White" TextAlignment="Right"/>
                                                <TextBlock Text="Dashboard hub for every major workflow" Style="{StaticResource Text.CaptionStrong}" Foreground="#D8F6FF" Margin="0,12,0,0" TextAlignment="Right"/>
                                                <Border Style="{StaticResource InfoBanner}" Background="#145A52" BorderBrush="#78D3C4" Padding="12,10" Margin="0,14,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="DATABASE" Foreground="#D7FFF8" FontSize="11" FontWeight="SemiBold" TextAlignment="Right"/>
                                                        <TextBlock Text="CONNECTED" Foreground="White" FontSize="20" FontWeight="Bold" TextAlignment="Right"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Dashboard" Style="{StaticResource Text.PageTitle}"/>
                                        <TextBlock Text="Use the dashboard as the main launch point for every module in the system." Style="{StaticResource Text.Subtitle}"/>
                                    </StackPanel>

                                    <Button x:Name="btnDashboardRefresh"
                                            Grid.Column="1"
                                            Content="Refresh"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource PageActionButton}"/>
                                </Grid>
                            </StackPanel>

                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                                <controls:StatCard x:Name="cardTotalStudents" Title="Total Students" Value="0" Hint="Active student records"/>
                                <controls:StatCard x:Name="cardEnrolledStudents" Title="Enrolled Students" Value="0" Hint="Currently enrolled learners"/>
                                <controls:StatCard x:Name="cardPendingEnrollments" Title="Pending Enrollments" Value="0" Hint="Awaiting approval or review"/>
                                <controls:StatCard x:Name="cardTotalTeachers" Title="Total Teachers" Value="0" Hint="Active teacher records"/>
                                <controls:StatCard x:Name="cardAvailableSections" Title="Available Sections" Value="0" Hint="Sections with remaining capacity"/>
                                <controls:StatCard x:Name="cardArchivedRecords" Title="Archived Records" Value="0" Hint="Non-restored archived items"/>
                            </UniformGrid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <controls:SectionHeader Grid.Row="0"
                                                                Title="Main Navigation"
                                                                Subtitle="Launch the major operational areas from one dashboard surface"
                                                                Margin="0,0,0,8"/>

                                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                                <Button x:Name="btnHubStudents" Style="{StaticResource DashboardHubTileButton}" Background="#147A78" BorderBrush="#49B8B0" Foreground="White" Margin="0,0,10,10">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Students" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Manage student identity, profiles, accounts, and status." Style="{StaticResource Text.Caption}" Foreground="#E6FFFD" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubTeachers" Style="{StaticResource DashboardHubTileButton}" Background="#2C6FA3" BorderBrush="#78B7E8" Foreground="White" Margin="0,0,10,10">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Teachers" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Open teacher records, credentials, and activity controls." Style="{StaticResource Text.Caption}" Foreground="#EEF8FF" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubEnrollment" Style="{StaticResource DashboardHubTileButton}" Background="#0F8F67" BorderBrush="#54D2A6" Foreground="White" Margin="0,0,10,10">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Enrollment" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Process applications, approvals, transfers, and queue actions." Style="{StaticResource Text.Caption}" Foreground="#E7FFF5" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubReports" Style="{StaticResource DashboardHubTileButton}" Background="#D08A19" BorderBrush="#F4C966" Foreground="White" Margin="0,0,0,10">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Reports" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Generate dashboard outputs, exports, and report presets." Style="{StaticResource Text.Caption}" Foreground="#FFF8E8" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubMasterData" Style="{StaticResource DashboardHubTileButton}" Background="#7D4C9E" BorderBrush="#BE92DB" Foreground="White" Margin="0,0,10,0">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Master Data" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="School settings, years, grade levels, subjects, curriculum, and sections." Style="{StaticResource Text.Caption}" Foreground="#F7EEFF" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubScheduling" Style="{StaticResource DashboardHubTileButton}" Background="#356D55" BorderBrush="#83C7A5" Foreground="White" Margin="0,0,10,0">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Scheduling" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Offerings, schedules, rooms, time slots, and teacher loads." Style="{StaticResource Text.Caption}" Foreground="#ECFFF4" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubAccountsCompliance" Style="{StaticResource DashboardHubTileButton}" Background="#BF5B22" BorderBrush="#F0A46C" Foreground="White" Margin="0,0,10,0">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Accounts &amp; Compliance" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Student accounts, requirements, archive center, and compliance actions." Style="{StaticResource Text.Caption}" Foreground="#FFF1E7" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnHubMaintenance" Style="{StaticResource DashboardHubTileButton}" Background="#A33B34" BorderBrush="#E08780" Foreground="White">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                                        <TextBlock Grid.Row="1" Text="Maintenance" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                                        <TextBlock Grid.Row="2" Text="Backup, restore, and year-end rollover administration." Style="{StaticResource Text.Caption}" Foreground="#FFF0EF" TextWrapping="Wrap"/>
                                    </Grid>
                                </Button>
                                        </UniformGrid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <controls:SectionHeader Grid.Row="0"
                                                                    Title="Recent Activity"
                                                                    Subtitle="Latest audit and operational actions across the system"
                                                                    Margin="0,0,0,8"/>
                                            <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                                <TextBlock x:Name="txtDashboardUpdatedAt" Style="{StaticResource Text.CaptionStrong}"/>
                                            </Border>
                                            <DataGrid Grid.Row="2"
                                                      x:Name="gridDashboardActivity"
                                                      MinHeight="220"
                                                      MaxHeight="320"
                                                      IsReadOnly="True"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <controls:SectionHeader Grid.Row="0"
                                                                    Title="Operational Watchlist"
                                                                    Subtitle="Current queue, reversal, waitlist, and critical operations signals"
                                                                    Margin="0,0,0,8"/>
                                            <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                                <TextBlock x:Name="txtDashboardQueueMetric" Style="{StaticResource Text.CaptionStrong}" TextWrapping="Wrap"/>
                                            </Border>
                                            <Border Grid.Row="2" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                                <TextBlock x:Name="txtDashboardReversalMetric" Style="{StaticResource Text.CaptionStrong}" TextWrapping="Wrap"/>
                                            </Border>
                                            <Border Grid.Row="3" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                                <TextBlock x:Name="txtDashboardWaitlistMetric" Style="{StaticResource Text.CaptionStrong}" TextWrapping="Wrap"/>
                                            </Border>
                                            <Border Grid.Row="4" Style="{StaticResource InfoBanner}">
                                                <TextBlock x:Name="txtDashboardCriticalOpsMetric" Style="{StaticResource Text.CaptionStrong}" TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>

                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Students -->
                    <TabItem Header="Students">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <Button x:Name="btnStudentsRefresh" Content="Refresh" Width="100" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
                                <Button x:Name="btnStudentsNew" Content="New Student" Width="120" Style="{StaticResource SecondaryActionButton}" DockPanel.Dock="Right" Margin="0,0,8,0"/>
                                <controls:SectionHeader Title="Students"
                                                        Subtitle="Manage student identity records, linked accounts, and status"/>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.55*"/>
                                    <ColumnDefinition Width="420"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.4*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                </Grid.ColumnDefinitions>
                                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="{StaticResource Icon.Search}" Style="{StaticResource GlyphIcon}" Margin="0,0,8,0"/>
                                                    <TextBox x:Name="txtStudentSearch" VerticalAlignment="Center" ToolTip="Search by Student No, LRN, Account ID, Name, or Status"/>
                                                </DockPanel>
                                                <ComboBox Grid.Column="1" x:Name="cboStudentTableGrade" Margin="0,0,8,0"/>
                                                <ComboBox Grid.Column="2" x:Name="cboStudentTableStatus"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="1" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtStudentsWorkspaceInfo" Style="{StaticResource Text.Caption}"/>
                                        </Border>
                                        <DataGrid Grid.Row="2" x:Name="gridStudents"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <controls:SectionHeader Title="Student Details" Subtitle="Identity, contact, preferences, and linked account overview" Margin="0,0,0,8"/>

                                            <Border x:Name="studentValidationSummaryHost"
                                                    Style="{StaticResource ErrorBanner}"
                                                    Visibility="Collapsed"
                                                    Margin="0,0,0,10">
                                                <TextBlock x:Name="txtStudentValidationSummary"
                                                           Foreground="{StaticResource Brush.Danger}"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <Border Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Identity and Account" Style="{StaticResource Text.CaptionStrong}" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Row="0" Grid.ColumnSpan="2" Content="Student Number"/>
                                                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" x:Name="txtStudentNumber" IsReadOnly="True" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="2" Grid.ColumnSpan="2" Content="LRN"/>
                                                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" x:Name="txtStudentLrn" Margin="0,0,0,8"/>

                                                    <Label Grid.Row="4" Grid.ColumnSpan="2" Content="Profile Image Path"/>
                                                    <TextBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="txtStudentProfileImage"/>
                                                </Grid>
                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

