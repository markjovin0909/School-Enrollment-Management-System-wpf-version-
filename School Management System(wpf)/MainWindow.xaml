                                        <TextBlock Text="Report type is the primary selector. Filters narrow the current result set, while presets store reusable combinations."
                                                   TextWrapping="Wrap"/>
                                    </Border>

                                    <UniformGrid Grid.Row="2" Columns="4">
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="Report Type"/>
                                            <ComboBox x:Name="cboReportType"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="School Year"/>
                                            <ComboBox x:Name="cboReportSchoolYear"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <Label Content="Grade"/>
                                            <ComboBox x:Name="cboReportGrade"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <Label Content="Section"/>
                                            <ComboBox x:Name="cboReportSection"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Status"/>
                                            <ComboBox x:Name="cboReportStatus"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Student"/>
                                            <ComboBox x:Name="cboReportStudent"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Label Content="Actions"/>
                                            <WrapPanel>
                                                <Button x:Name="btnReportLoad" Content="Load Report" Width="120" Margin="0,0,8,0"/>
