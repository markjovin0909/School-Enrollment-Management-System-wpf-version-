                                            <TextBlock x:Name="txtEnrollStaleMessage" Style="{StaticResource Text.Caption}" TextWrapping="Wrap"/>
                                        </Border>

                                        <Border Style="{StaticResource InfoBanner}" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="Review Context" Style="{StaticResource Text.CaptionStrong}"/>
