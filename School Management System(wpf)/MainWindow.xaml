                                        </Border>
                                        <TextBlock Text="Launch Modules" Style="{StaticResource Text.CaptionStrong}"/>
                                        <TextBlock Text="Open safeguard utilities in a dedicated workspace." Style="{StaticResource Text.Caption}" Margin="0,2,0,10"/>
                                        <Button x:Name="btnOpsBackup" Content="Backup / Restore" Style="{StaticResource OpsModuleButton}"/>
                                        <Button x:Name="btnOpsYearEnd" Content="Year-End Rollover" Style="{StaticResource OpsModuleButton}" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardPanel}" MinWidth="540">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource InfoBanner}" Margin="0,0,0,8">
                                            <TextBlock x:Name="txtMaintenanceWorkspaceInfo" Style="{StaticResource Text.Caption}"/>
                                        </Border>

                                        <Grid Grid.Row="1">
                                            <ContentControl x:Name="hostMaintenanceModule" Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtMaintenanceModulePlaceholder"
                                                       Text="Select a module from the launch list to open its workspace here."
                                                       Style="{StaticResource Text.Subtitle}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
