                                        <TextBox Grid.Row="3" Grid.Column="0" x:Name="txtTDFirstName" IsReadOnly="True" Margin="0,0,6,8"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtTDLastName" IsReadOnly="True" Margin="6,0,6,8"/>
                                        <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtTDMiddleName" IsReadOnly="True" Margin="6,0,0,8"/>

                                        <Label Grid.Row="4" Grid.Column="0" Content="Email"/>
                                        <Label Grid.Row="4" Grid.Column="1" Content="Contact No"/>
                                        <Label Grid.Row="4" Grid.Column="2" Content="Employment Status"/>
                                        <TextBox Grid.Row="5" Grid.Column="0" x:Name="txtTDEmail" IsReadOnly="True" Margin="0,0,6,8"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtTDContactNo" IsReadOnly="True" Margin="6,0,6,8"/>
                                        <ComboBox Grid.Row="5" Grid.Column="2" x:Name="cboTDEmploymentStatus" IsEnabled="False" Margin="6,0,0,8"/>

                                        <Label Grid.Row="6" Grid.Column="0" Content="Hire Date"/>
                                        <Label Grid.Row="6" Grid.Column="1" Content="Advisory Status"/>
                                        <DatePicker Grid.Row="7" Grid.Column="0" x:Name="dpTDHireDate" IsEnabled="False" Margin="0,0,6,0"/>
                                        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cboTDAdvisoryStatus" IsEnabled="False" Margin="6,0,6,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Handled Subjects -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Handled Subjects"
                                                            Subtitle="Class offerings assigned to this teacher"
                                                            Margin="0,0,0,10"/>

                                    <DataGrid Grid.Row="1"
                                              x:Name="gridTDSubjects"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              MaxHeight="200"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                                            <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="150"/>
                                            <DataGridTextColumn Header="Grade Level" Binding="{Binding GradeLevel}" Width="120"/>
                                            <DataGridTextColumn Header="School Year" Binding="{Binding SchoolYear}" Width="120"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- Handled Sections -->
                            <Border Grid.Row="4" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Handled Sections"
                                                            Subtitle="Sections where this teacher has class offerings. Double-click to view students."
                                                            Margin="0,0,0,10"/>

                                    <DataGrid Grid.Row="1"
                                              x:Name="gridTDSections"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              MaxHeight="200"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Section" Binding="{Binding SectionName}" Width="*"/>
                                            <DataGridTextColumn Header="Grade Level" Binding="{Binding GradeLevel}" Width="120"/>
                                            <DataGridTextColumn Header="School Year" Binding="{Binding SchoolYear}" Width="120"/>
                                            <DataGridTextColumn Header="Students" Binding="{Binding StudentCount}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Enrollment Details (navigated from modal) -->
                    <TabItem Header="Enrollment Details">
                        <TabItem.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.MergedDictionaries>
                                    <ResourceDictionary Source="/Themes/LegacyAdminTheme.xaml"/>
                                </ResourceDictionary.MergedDictionaries>
                            </ResourceDictionary>
                        </TabItem.Resources>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <controls:SectionHeader x:Name="sectionEDHeader"
                                                        Title="Enrollment Details"
                                                        Subtitle="Student enrollment summary and class assignments"/>
                            </DockPanel>

                            <!-- Enrollment Info -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Enrollment Summary"
                                                            Subtitle="School year, grade level, section, curriculum, and status"
                                                            Margin="0,0,0,10"/>

                                    <UniformGrid Grid.Row="1" Columns="4">
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="School Year" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDSchoolYear" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="Grade Level" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDGradeLevel" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="Section" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDSection" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Curriculum" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDCurriculum" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Status" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStatus" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Enrolled At" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDEnrolledAt" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Student" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStudentName" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,0">
                                            <TextBlock Text="LRN" Style="{StaticResource Text.Caption}"/>
                                            <TextBlock x:Name="txtEDStudentLrn" Style="{StaticResource Text.Body}" Text="-"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <!-- Requirements -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Student Requirements"
                                                            Subtitle="Document submission checklist for this student"
                                                            Margin="0,0,0,10"/>

                                    <DataGrid Grid.Row="1"
                                              x:Name="gridEDRequirements"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              MaxHeight="180"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Requirement" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                            <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- Subjects -->
                            <Border Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <controls:SectionHeader Grid.Row="0"
                                                            Title="Enrolled Subjects"
                                                            Subtitle="Class offerings assigned to this student in the enrolled section"
                                                            Margin="0,0,0,10"/>

                                    <DataGrid Grid.Row="1"
                                              x:Name="gridEDSubjects"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              MaxHeight="180"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                                            <DataGridTextColumn Header="Teacher" Binding="{Binding TeacherName}" Width="160"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
